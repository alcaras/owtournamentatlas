---
import Base from '../layouts/Base.astro';
import atlas from '../data/atlas-all.json';
import tour from '../data/tournament-games.json';
const base = import.meta.env.BASE_URL;

// quick per-script summary: city-site avg range + which size/aspect/sym
// hits the target band most (informational, not a recommendation).
function summary(s: any) {
  const cs = s.cells.map((c: any) => c.mean);
  const best = [...s.cells].sort((a: any, b: any) => b.pctTarget - a.pctTarget)[0];
  return {
    siteLo: Math.min(...cs).toFixed(0),
    siteHi: Math.max(...cs).toFixed(0),
    best: `${best.sizeLabel}/${best.aspect}/${best.pointSymmetry ? 'sym' : 'nosym'}`,
    bestPct: best.pctTarget,
  };
}
---
<Base title="Map Atlas">
  <p class="lede">
    Empirical, blind-random analysis of Old World map scripts for
    tournament organizers — generated by running the game's own
    map-generation & start-placement code, even-r model verified against
    the game source. {atlas.scripts.length} scripts ·
    {atlas.seedsPerCell} maps per setting ·
    {tour.count} real tournament games for calibration.
  </p>

  <div class="grid">
    {atlas.scripts.map(s => {
      const u = summary(s);
      return (
        <a class="card" href={`${base}${s.slug}`}>
          <div class="card__name">{s.label}</div>
          <div class="card__meta">
            city sites ≈ {u.siteLo}–{u.siteHi} · {s.cells.length} settings
          </div>
          <div class="card__meta card__dim">best {atlas.target[0]}–{atlas.target[1]} band: {u.best} ({u.bestPct}%)</div>
        </a>
      );
    })}
  </div>

  <a class="cal" href={`${base}calibration`}>
    → {tour.count} completed tournament games (calibration data)
  </a>

  <style>
    .lede { font-family: var(--font-display); font-style: italic; font-size: 1.05rem;
      line-height: 1.55; color: var(--text-soft); max-width: 72ch; margin: 0.7rem 0 1.6rem; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:0.8rem; }
    .card { display:block; background:var(--bg-elev); border:1px solid var(--border);
      border-radius:5px; padding:0.9rem 1.1rem; text-decoration:none; color:inherit;
      transition:border-color .15s, transform .15s; }
    .card:hover { border-color:var(--gold); transform:translateY(-1px); text-decoration:none; }
    .card__name { font-family:var(--font-display); font-weight:700; font-size:1.3rem; color:var(--text); }
    .card__meta { font-size:0.8rem; color:var(--text-soft); margin-top:0.25rem; }
    .card__dim { color:var(--text-faint); font-size:0.74rem; }
    .cal { display:inline-block; margin-top:1.6rem; font-family:var(--font-ui);
      font-size:0.85rem; color:var(--gold-soft); }
    .cal:hover { color:var(--gold); }
  </style>
</Base>
