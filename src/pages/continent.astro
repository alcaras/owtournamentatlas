---
import Base from '../layouts/Base.astro';
import atlas from '../data/continent-atlas.json';

const base = import.meta.env.BASE_URL;
const [tlo, thi] = atlas.target;
const [alo, ahi] = atlas.accept;

const sym = (b: boolean) => (b ? 'on' : '—');
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const cd = (c: any) => c.capitalDistance;
// format a {mean,sd,min,max} stats object → "avg ±sd [min–max]"
const fd = (o: any) => o == null ? '—'
  : `<b>${o.mean.toFixed(0)}</b> <span class="dim">±${o.sd.toFixed(0)} [${o.min}–${o.max}]</span>`;

const aspOrd: Record<string, number> = { square: 0, wide: 1, ultrawide: 2 };
const cells = [...atlas.cells].sort((a, b) =>
  (a.size === b.size ? 0 : a.size === 'smallest' ? -1 : 1) ||
  (Number(a.pointSymmetry) - Number(b.pointSymmetry)) ||
  (aspOrd[a.aspect] - aspOrd[b.aspect]));

// preview renders are generated for one fixed variant (currently Tiny/
// square/no-sym) purely so organizers can see what the script looks like.
const previewLabel = atlas.recommended
  ? `${atlas.recommended.sizeLabel} · ${cap(atlas.recommended.aspect)}` +
    (atlas.recommended.pointSymmetry ? ' · pt-sym' : '')
  : 'sample';
---

<Base title="Continent">
  <p class="lede">
    Blind, random tournament maps — players don't see them in advance.
    Each row is one <b>size + point-symmetry + aspect</b> setting,
    measured over {atlas.seedsPerCell} generated Continent maps
    (2 players, mirror always on). Two things only for now:
    <b>how many city sites</b> and <b>how far apart the capitals are</b>.
  </p>

  <h2 class="sec">City sites &amp; capital distance — every setting</h2>
  <p class="note">
    City-site target band {tlo}–{thi} (acceptable {alo}–{ahi});
    “In {tlo}–{thi}” = share of random maps in the band. Distance cells
    show <b>avg ±sd [min–max]</b> — the spread matters as much as the
    average. <b>Crow-flies</b> = straight hex distance (terrain ignored).
    <b>Land path</b> = hex land route; <b>Land-conn</b> = % of maps with
    any land route (low ⇒ some maps are naval-only). <b>Scout</b> =
    orders for a Scout (move 3) to reach the other capital — how fast
    players make first contact. <b>Slinger</b> (move 2, “army gets
    there”): land / sea (coastal) / Hatti (ignores hill). Exploration
    law assumed (rivers fast). Pick a row good on <i>both</i> sides.
  </p>
  <div class="tscroll">
    <table class="tbl">
      <thead><tr>
        <th>Size</th><th>Pt-sym</th><th>Aspect</th><th>Dims</th>
        <th>City sites avg</th><th>±sd</th><th>Med</th><th>Min–Max</th>
        <th>In {tlo}–{thi}</th><th>In {alo}–{ahi}</th>
        <th class="sep">Crow-flies</th><th>Land path</th><th>Land-conn</th>
        <th>Scout (contact)</th><th>Slinger land</th><th>Slinger sea</th><th>Slinger Hatti</th>
      </tr></thead>
      <tbody>
        {cells.map(c => {
          const sl = c.slingerTurns || {};
          return (
            <tr>
              <td>{c.sizeLabel}</td>
              <td>{sym(c.pointSymmetry)}</td>
              <td class="cap">{c.aspect}</td>
              <td class="mono">{c.dims}</td>
              <td><b>{c.mean.toFixed(1)}</b></td>
              <td class="mono dim">±{c.sd.toFixed(1)}</td>
              <td class="mono">{c.median}</td>
              <td class="mono">{c.min}–{c.max}</td>
              <td class={c.pctTarget >= 40 ? 'good' : c.pctTarget >= 20 ? '' : 'bad'}>{c.pctTarget}%</td>
              <td>{c.pctAccept}%</td>
              <td class="mono sep" set:html={fd(cd(c))} />
              <td class="mono" set:html={fd(c.landPath)} />
              <td class={c.landConnectedPct != null && c.landConnectedPct < 100 ? 'bad' : ''}>
                {c.landConnectedPct ?? 100}%</td>
              <td class="mono" set:html={fd(c.scoutOrders)} />
              <td class="mono" set:html={fd(sl.land)} />
              <td class="mono" set:html={fd(sl.sea)} />
              <td class="mono" set:html={fd(sl.hatti)} />
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <h2 class="sec">What the maps look like</h2>
  <p class="note">{atlas.previews.length} random {previewLabel} maps.
    Gold = city sites · red = tribe sites · terrain coloured like the
    minimap. (Sample variant only — not a recommendation.)</p>
  <div class="gallery">
    {atlas.previews.map((p: string, i: number) => (
      <figure><img src={`${base}img/${p}`} alt={`Continent sample ${i + 1}`} loading="lazy" /></figure>
    ))}
  </div>

  <p class="note" style="margin-top:1.4rem;">
    <b>Movement proxy.</b> Scout = move 3 (first contact); Slinger =
    move 2 (army). Tile cost = terrain + height + vegetation: flat = 1
    move; sand/marsh/forest/jungle = 2; <b>hill +1</b>;
    mountains/volcanoes impassable. <b>Forest IS penalised</b> (×2).
    Exploration law assumed → river tiles are fast corridors (cost 6)
    and there is <b>no river-crossing penalty</b> (rivers help, not
    hinder). Turns ≈ ceil(path cost ÷ move/turn); one Order per turn
    moved, so turns ≈ orders. Hatti = Slinger ignoring hill cost. Sea =
    coastal/anchored-boat proxy (flat per water tile). Ignored: “always
    move ≥1 tile/turn”, movement carry-over, roads, ZoC, embark cost.
  </p>
  <p class="prov">owmapgen <span class="mono">{atlas.owmapgenSha}</span> ·
    sweep <span class="mono">{atlas.atlasId}</span> ·
    {atlas.seedsPerCell} seeds/cell.</p>
</Base>

<style>
  .lede {
    font-family: var(--font-display); font-style: italic;
    font-size: 1.05rem; line-height: 1.55; color: var(--text-soft);
    max-width: 72ch; margin: 0.6rem 0 1.6rem;
  }
  .sec {
    font-size: 1.4rem; margin: 2rem 0 0.3rem;
    border-bottom: 1px solid var(--gold-deep); padding-bottom: 0.3rem;
  }
  .note { font-size: 0.82rem; color: var(--text-faint); margin: 0.3rem 0 0.7rem; line-height: 1.5; max-width: 80ch; }
  .tscroll { overflow-x: auto; }
  .tbl { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
  .tbl thead th {
    font-family: var(--font-ui); font-size: 0.58rem; letter-spacing: 0.13em;
    text-transform: uppercase; color: var(--text-dim); font-weight: 600;
    text-align: left; padding: 0.35rem 0.65rem; border-bottom: 1px solid var(--border-strong);
    white-space: nowrap;
  }
  .tbl td { padding: 0.4rem 0.65rem; border-bottom: 1px solid var(--border); white-space: nowrap; }
  .tbl tbody tr:hover td { background: #1c1f25; }
  .mono { font-family: var(--font-mono); font-size: 0.82em; }
  .cap { text-transform: capitalize; }
  .dim { color: var(--text-faint); }
  .good { color: #7fb069; font-weight: 600; }
  .bad { color: #b06a5f; }
  .gallery {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.6rem; margin-top: 0.6rem;
  }
  .gallery figure { margin: 0; background: var(--bg-elev); border: 1px solid var(--border); border-radius: 4px; padding: 0.3rem; }
  .gallery img { width: 100%; height: auto; display: block; image-rendering: pixelated; border-radius: 2px; }
  .prov { margin-top: 1rem; font-size: 0.72rem; color: var(--text-faint); font-family: var(--font-mono); border-top: 1px solid var(--border); padding-top: 0.7rem; }
</style>
