---
import Base from '../layouts/Base.astro';
import gensData from '../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

// ---- Round 2 ballot — designed for CLARITY, not a full re-vote ------
// Of the 33 reliable configs (≥70% in both the 14–26 site & 40–60 land
// windows), Round 1 already settled some. Round 2 only asks what a vote
// can still change:
//   LOCKED   — reliable + near-unanimous Round 1 like → IN, no vote.
//   CONTESTED — reliable but Round 1 votes were split → needs a verdict.
//   UNVOTED  — reliable but never balloted (the new grid) → first look.
// hardwood-forest-tiny-square-nosym is reliable but Round 1 rejected it
// (2 like / 4 no) — settled OUT, off the ballot.
const SITES_LO = 14, SITES_HI = 26, LAND_LO = 40, LAND_HI = 60;
const THRESH = 0.70;

const LOCKED = [
  'coastal-rain-basin-smallest-wide-nosym',
  'arid-plateau-small-seas-smallest-square-sym',
  'inland-sea-smallest-square-sym',
  'dota-jungle-smallest-square-sym',
];
const CONTESTED = [
  'coastal-rain-basin-smallest-square-sym',
  'dota-jungle-smallest-wide-sym',
  'arid-plateau-small-seas-smallest-wide-nosym',
  'dota-water-smallest-square-sym',
  'dota-sand-smallest-wide-sym',
  'continent-tiny-square-sym',
  'coastal-rain-basin-smallest-wide-sym',
  'wetlands-smallest-square-sym',
  'dota-water-smallest-wide-sym',
  'desert-none-std-tiny-square-sym',
  'archipelago-land-lg-water-sm-smallest-square-sym',
  'inland-sea-smallest-wide-nosym',
  'continent-tiny-square-nosym',
  'hardwood-forest-tiny-square-sym',
  'donut-irreg-low-tiny-square-nosym',
];
const UNVOTED = [
  'highlands-tiny-square-sym',
  'mountain-pass-smallest-wide-sym',
  'donut-irreg-low-tiny-square-sym',
  'arid-plateau-large-seas-smallest-square-sym',
  'arid-plateau-large-seas-smallest-wide-nosym',
  'arid-plateau-large-seas-smallest-wide-sym',
  'inland-sea-smallest-square-nosym',
  'desert-lush-std-tiny-square-nosym',
  'desert-dry-std-tiny-wide-nosym',
  'desert-none-std-tiny-wide-nosym',
  'mountain-pass-tiny-square-nosym',
  'wetlands-smallest-square-nosym',
  'highlands-tiny-wide-nosym',
];
// Round 1 tally — [like, maybe, no] over the 7 non-organiser voters.
const R1: Record<string, [number, number, number]> = {
  'coastal-rain-basin-smallest-wide-nosym': [7, 0, 0],
  'arid-plateau-small-seas-smallest-square-sym': [7, 0, 0],
  'inland-sea-smallest-square-sym': [7, 0, 0],
  'dota-jungle-smallest-square-sym': [6, 0, 1],
  'coastal-rain-basin-smallest-square-sym': [5, 1, 1],
  'dota-jungle-smallest-wide-sym': [5, 0, 1],
  'arid-plateau-small-seas-smallest-wide-nosym': [4, 1, 1],
  'dota-water-smallest-square-sym': [4, 2, 1],
  'dota-sand-smallest-wide-sym': [4, 1, 1],
  'continent-tiny-square-sym': [4, 1, 2],
  'coastal-rain-basin-smallest-wide-sym': [4, 0, 2],
  'wetlands-smallest-square-sym': [3, 3, 0],
  'dota-water-smallest-wide-sym': [3, 2, 1],
  'desert-none-std-tiny-square-sym': [3, 2, 1],
  'archipelago-land-lg-water-sm-smallest-square-sym': [3, 1, 2],
  'inland-sea-smallest-wide-nosym': [2, 2, 2],
  'continent-tiny-square-nosym': [2, 1, 3],
  'hardwood-forest-tiny-square-sym': [1, 3, 2],
  'donut-irreg-low-tiny-square-nosym': [0, 3, 3],
};

type G = { cslug: string; sites: number; land: number; slLand: number;
  label: string; group: string; setting: string; id: string;
  img: string; seed: number };
const byCfg: Record<string, G[]> = {};
for (const g of (gensData as any).gens as G[]) (byCfg[g.cslug] ??= []).push(g);

type Stat = { mean: number; sd: number; med: number; min: number;
  max: number };
function stats(vals: number[]): Stat {
  const s = [...vals].sort((a, b) => a - b), n = s.length;
  const mean = s.reduce((a, b) => a + b, 0) / n;
  const sd = Math.sqrt(s.reduce((a, b) => a + (b - mean) ** 2, 0) / n);
  return { mean: Math.round(mean * 10) / 10,
    sd: Math.round(sd * 10) / 10, med: s[n >> 1], min: s[0], max: s[n - 1] };
}
const pc = (x: number) => Math.round(x * 100);

type Cfg = {
  slug: string; group: string; variant: string; n: number; rows: G[];
  setting: string[]; sitePct: number; landPct: number;
  sites: Stat; land: Stat; move: Stat; r1: [number, number, number] | null;
};
function build(slug: string): Cfg {
  const rows = (byCfg[slug] || []).slice().sort((a, b) => a.seed - b.seed);
  const n = rows.length || 1;
  const r0 = rows[0] || ({} as G);
  const parts = (r0.label || slug).split(' · ');
  return {
    slug, group: r0.group || '', variant: parts.slice(1, -1).join(' · '),
    n, rows, setting: (r0.setting || '').split(' · ').filter((p) => p !== 'mirror'),
    sitePct: rows.filter((g) => g.sites >= SITES_LO && g.sites <= SITES_HI).length / n,
    landPct: rows.filter((g) => g.land >= LAND_LO && g.land <= LAND_HI).length / n,
    sites: stats(rows.map((g) => g.sites)),
    land: stats(rows.map((g) => g.land)),
    move: stats(rows.map((g) => g.slLand)),
    r1: R1[slug] || null,
  };
}
const locked = LOCKED.map(build);
const contested = CONTESTED.map(build)
  .sort((a, b) => (b.r1![0] * 2 - b.r1![2]) - (a.r1![0] * 2 - a.r1![2]));
const unvoted = UNVOTED.map(build)
  .sort((a, b) => (b.sitePct + b.landPct) - (a.sitePct + a.landPct));
const N = contested.length + unvoted.length;
const PREVIEWS = 6;

// short labels for the sidebar jump-chips
const SHORT: Record<string, string> = {
  'Continent': 'Cont', 'Coastal Rain Basin': 'CRB', 'Donut': 'Donut',
  'Archipelago': 'Arch', 'Arid Plateau': 'Arid', 'DOTA': 'DOTA',
  'Hardwood Forest': 'Hardwd', 'Inland Sea': 'Inland', 'Desert': 'Desert',
  'Mountain Pass': 'MtnPass', 'Wetlands': 'Wet', 'Highlands': 'Highl',
};
const abbr = (c: Cfg) => {
  const sz = c.setting[0] === 'Duel' ? 'D' : 'T';
  const asp = c.setting[1] === 'square' ? 'sq' : 'w';
  const sym = (c.setting[2] || '').includes('on') ? 's' : 'n';
  const v = c.variant ? ' ' + c.variant.split(' · ')[0].slice(0, 4) : '';
  return `${SHORT[c.group] || c.group}${v} ${sz}·${asp}·${sym}`;
};
---
<Base title="Round 2 Voting">
  <p class="lede">
    <b>Round 2 — built for clarity, not a re-vote.</b> Every config here
    is <b>reliable</b> (≥{pc(THRESH)}% of seeds inside both the
    {SITES_LO}–{SITES_HI} city-site and {LAND_LO}–{LAND_HI} land-hex
    windows). Round 1 already settled the obvious ones — those are
    <b>locked in</b> below, no vote needed. You only vote on the
    {N} where a vote still changes the answer: the <b>{contested.length}
    contested</b> (Round 1 was split) and the <b>{unvoted.length} never
    balloted</b> (the new size/aspect/sym variants — first look).
  </p>

  <nav class="snav" id="snav">
    <button id="copyv" class="snav__cv">⬇ COPY ROUND-2 VOTES</button>
    <div class="snav__c">voted <b id="vc">0</b> / {N}<span id="alldone" class="alldone" hidden>✓ all in</span></div>
    <div class="snav__tly">
      <span class="tly tly-like">👍 <b id="t-like">0</b></span>
      <span class="tly tly-maybe">🤷 <b id="t-maybe">0</b></span>
      <span class="tly tly-no">👎 <b id="t-no">0</b></span>
    </div>
    {[
      { href: '#locked', label: `✓ Locked in · ${locked.length}`,
        list: locked, vote: false },
      { href: '#contested', label: `① Contested · ${contested.length}`,
        list: contested, vote: true },
      { href: '#unvoted', label: `② First look · ${unvoted.length}`,
        list: unvoted, vote: true },
    ].map((sec) => (
      <div class="ngsec">
        <a class="snav__lnk" href={sec.href}>{sec.label}</a>
        <div class="chips">
          {sec.list.map((c) => (
            <a class={'vchip' + (sec.vote ? '' : ' vchip--lock')}
               href={`#cfg-${c.slug}`} title={c.group + (c.variant ? ' · ' + c.variant : '')}
               data-slug={sec.vote ? c.slug : undefined}>{abbr(c)}</a>
          ))}
        </div>
      </div>
    ))}
  </nav>

  <div class="rmain">
    <section id="locked">
      <h2 class="grp__h">✓ Locked in — already voted in, no vote needed</h2>
      <p class="grp__sub">Reliable and near-unanimous in Round 1. Shown
        for reference; these are in the pool.</p>
      {locked.map((c) => (
        <div class="cfg cfg--lock" id={`cfg-${c.slug}`}>
          <div class="cfg__hd">
            <span class="lockin">✓ IN</span>
            <span class="cfg__name">{c.group}{c.variant ? ` · ${c.variant}` : ''}</span>
            <span class="cfg__chips">
              {c.setting.map((p) => (<span class="ch">{p}</span>))}
            </span>
            <span class="rels">
              <span class={'rel ' + (c.sitePct >= THRESH ? 'rel--ok' : 'rel--lo')}>sites {pc(c.sitePct)}%</span>
              <span class={'rel ' + (c.landPct >= THRESH ? 'rel--ok' : 'rel--lo')}>land {pc(c.landPct)}%</span>
              <span class="r1">R1 {c.r1![0]}L·{c.r1![1]}M·{c.r1![2]}N</span>
            </span>
          </div>
          <div class="mini">
            <span><i>city sites</i><b>{c.sites.mean}</b></span>
            <span><i>land hex</i><b>{c.land.mean}</b></span>
            <span><i>land cost</i><b>{c.move.mean}</b></span>
          </div>
        </div>
      ))}
    </section>

    {[
      { id: 'contested', list: contested, n: 1,
        title: 'Contested — Round 1 was split, pick the verdict',
        sub: 'These cleared the reliability bar but Round 1 votes were mixed. Mostly “which variant of a script that’s already in”, or a straight in/out.' },
      { id: 'unvoted', list: unvoted, n: 2,
        title: 'First look — reliable, never balloted',
        sub: 'New size/aspect/symmetry variants (incl. Arid Large Seas and the Tiny grid) — nobody has voted on these. This is where Round 2 buys the most clarity, and the path back to Tiny / wide / no-sym variety.' },
    ].map((sec) => (
      <section id={sec.id}>
        <h2 class="grp__h">{sec.n === 1 ? '①' : '②'} {sec.title}</h2>
        <p class="grp__sub">{sec.sub}</p>
        {sec.list.map((c) => (
          <div class="cfg" id={`cfg-${c.slug}`} data-slug={c.slug}>
            <div class="cfg__hd">
              <span class="cfg__name">{c.group}{c.variant ? ` · ${c.variant}` : ''}</span>
              <span class="cfg__chips">
                {c.setting.map((p) => (<span class="ch">{p}</span>))}
              </span>
              <span class="rels">
                <span class={'rel ' + (c.sitePct >= THRESH ? 'rel--ok' : 'rel--lo')}>sites 14–26 <b>{pc(c.sitePct)}%</b></span>
                <span class={'rel ' + (c.landPct >= THRESH ? 'rel--ok' : 'rel--lo')}>land 40–60 <b>{pc(c.landPct)}%</b></span>
                {c.r1
                  ? <span class="r1">Round 1: {c.r1[0]}L · {c.r1[1]}M · {c.r1[2]}N</span>
                  : <span class="r1 r1--new">first look — no Round 1 vote</span>}
              </span>
              <span class="vote" data-slug={c.slug}>
                <button data-v="like">👍 like</button>
                <button data-v="maybe">🤔 maybe</button>
                <button data-v="no">👎 no</button>
              </span>
            </div>
            <div class="pills">
              <div class="pill">
                <div class="pill__l">City sites</div>
                <div class="pill__v"><b>{c.sites.mean}</b> <span class="pm">±{c.sites.sd}</span></div>
                <div class="pill__r">min {c.sites.min} · <b>med {c.sites.med}</b> · max {c.sites.max}</div>
              </div>
              <div class="pill">
                <div class="pill__l">Land hex distance</div>
                <div class="pill__v"><b>{c.land.mean}</b> <span class="pm">±{c.land.sd}</span></div>
                <div class="pill__r">min {c.land.min} · <b>med {c.land.med}</b> · max {c.land.max}</div>
              </div>
              <div class="pill">
                <div class="pill__l">Land hex cost <span class="u">turns</span></div>
                <div class="pill__v"><b>{c.move.mean}</b> <span class="pm">±{c.move.sd}</span></div>
                <div class="pill__r">min {c.move.min} · <b>med {c.move.med}</b> · max {c.move.max}</div>
              </div>
            </div>
            <details class="gal" open>
              <summary>{Math.min(PREVIEWS, c.n)} of {c.n} map previews</summary>
              <div class="gal__grid">
                {c.rows.slice(0, PREVIEWS).map((r) => (
                  <a class="gal__cell" href={`${baseUrl}gen/${r.id}`}
                     target="_blank" rel="noopener">
                    <img src={`${baseUrl}img/${r.img}`} loading="lazy"
                         alt={`seed ${r.seed}`} />
                    <div class="cap">
                      <span><i>sites</i><b>{r.sites}</b></span>
                      <span><i>land</i><b>{r.land}</b></span>
                      <span><i>cost</i><b>{r.slLand}</b></span>
                    </div>
                  </a>
                ))}
              </div>
            </details>
          </div>
        ))}
      </section>
    ))}
  </div>

  <p class="note">
    {N} configs on the ballot ({contested.length} contested +
    {' '}{unvoted.length} first-look); {locked.length} more are locked in
    above. <b>City sites / Land hex distance / Land hex cost</b> are
    per-config means over the owmapgen sweep; the two badges are how
    often a config lands inside the {SITES_LO}–{SITES_HI} and
    {LAND_LO}–{LAND_HI} windows. Votes are stored locally, separate from
    Round 1; COPY emits an <code>OW-VOTES-R2</code> block.
  </p>

  <style>
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:84ch; margin:0.6rem 0 1.4rem; }
    .grp__h { font-size:1.4rem; color:var(--gold); border-bottom:1px solid
      var(--gold-deep); padding-bottom:0.3rem; margin:1.6rem 0 0.3rem;
      font-family:var(--font-display); font-weight:700; }
    .grp__sub { font-size:0.84rem; color:var(--text-faint);
      font-style:italic; font-family:var(--font-display);
      margin:0 0 0.7rem; max-width:84ch; }
    .cfg { background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.8rem 1rem; margin-bottom:0.8rem; }
    .cfg--lock { border-color:#3b6e3b; background:#13200f; }
    .cfg__hd { display:flex; align-items:baseline; gap:0.7rem; flex-wrap:wrap; }
    .cfg__name { font-family:var(--font-display); font-weight:700;
      font-size:1.18rem; color:var(--text); }
    .lockin { font-family:var(--font-ui); font-weight:800; font-size:0.66rem;
      letter-spacing:0.1em; color:#bfe89f; background:#1e4d18;
      border:1px solid #3b6e3b; border-radius:5px; padding:0.16rem 0.5rem; }
    .cfg__chips { display:inline-flex; gap:0.3rem; flex-wrap:wrap; }
    .ch { font-size:0.66rem; font-family:var(--font-mono);
      color:var(--text-soft); background:#0e0f12;
      border:1px solid var(--border-strong); border-radius:4px;
      padding:0.08rem 0.4rem; }
    .rels { display:inline-flex; gap:0.3rem; flex-wrap:wrap;
      align-items:center; }
    .rel { font-family:var(--font-ui); font-weight:600; font-size:0.64rem;
      letter-spacing:0.03em; padding:0.12rem 0.5rem; border-radius:999px;
      border:1px solid; white-space:nowrap; }
    .rel b { font-weight:800; }
    .rel--ok { color:#9fd07f; border-color:#3b6e3b; background:#16290f; }
    .rel--lo { color:#e0b061; border-color:var(--gold-deep); background:#231f0d; }
    .r1 { font-size:0.62rem; font-family:var(--font-mono);
      color:var(--text-faint); }
    .r1--new { color:#8fc0e8; }
    .vote { display:inline-flex; gap:0.4rem; margin-left:auto; }
    .vote button { background:#1b1d23; color:var(--text-soft);
      border:1px solid var(--border-strong); border-radius:7px;
      padding:0.34rem 0.8rem; font-size:0.85rem; font-weight:600;
      cursor:pointer; transition:transform .06s; }
    .vote button:hover { color:var(--text); transform:translateY(-1px); }
    .vote button.on[data-v="like"]  { background:#1e4d18; color:#bfe89f; border-color:#3b6e3b; box-shadow:0 0 0 1px #3b6e3b; }
    .vote button.on[data-v="maybe"] { background:#3a3110; color:#f0d27a; border-color:var(--gold-deep); box-shadow:0 0 0 1px var(--gold-deep); }
    .vote button.on[data-v="no"]    { background:#46211b; color:#eaa091; border-color:#5a2e28; box-shadow:0 0 0 1px #5a2e28; }
    .mini { display:flex; gap:1.4rem; margin-top:0.5rem; }
    .mini span { display:flex; flex-direction:column; gap:0.05rem; }
    .mini i { font-style:normal; font-size:0.58rem; letter-spacing:0.1em;
      text-transform:uppercase; color:var(--text-dim); }
    .mini b { font-family:var(--font-display); font-weight:700;
      font-size:1.3rem; color:var(--gold); }
    .pills { display:flex; flex-wrap:wrap; gap:0.8rem; margin-top:0.6rem; }
    .pill { flex:1 1 240px; background:#16181d;
      border:1px solid var(--gold-deep); border-radius:8px;
      padding:0.55rem 0.85rem; }
    .pill__l { font-size:0.64rem; letter-spacing:0.13em;
      text-transform:uppercase; color:var(--text-dim); }
    .pill__l .u { letter-spacing:0.05em; color:var(--text-faint);
      font-size:0.92em; }
    .pill__v { font-size:2.5rem; font-family:var(--font-display);
      font-weight:700; color:var(--gold); line-height:1.1;
      margin:0.05rem 0 0.1rem; }
    .pill__v .pm { font-size:0.95rem; color:var(--text-faint);
      font-family:var(--font-ui); font-weight:400; }
    .pill__r { font-size:0.71rem; color:var(--text-faint);
      font-family:var(--font-mono); }
    .pill__r b { color:var(--text-soft); }
    .snav { position:fixed; left:max(8px, calc((100vw - 1180px)/2 - 178px));
      top:84px; width:168px; display:flex; flex-direction:column;
      gap:0.12rem; font-size:0.78rem; max-height:calc(100vh - 100px);
      overflow:auto; z-index:20; }
    @media (max-width:1340px){ .snav{ left:8px; } }
    @media (max-width:990px){ .snav{ position:static; width:auto;
      flex-flow:row wrap; max-height:none; margin-bottom:1rem; } }
    .snav__cv { background:#231f0d; color:var(--gold); cursor:pointer;
      border:1px solid var(--gold-deep); border-radius:7px;
      padding:0.5rem 0.6rem; font-weight:700; font-size:0.8rem;
      margin-bottom:0.35rem; }
    .snav__cv:hover { background:#2e2810; }
    .snav__c { font-size:0.74rem; color:var(--text-soft);
      margin-bottom:0.4rem; } .snav__c b { color:var(--gold); }
    .snav__c .alldone { color:#bfe89f; margin-left:0.3rem; }
    .snav__tly { display:flex; gap:0.3rem; margin-bottom:0.6rem; }
    .tly { font-size:0.62rem; font-family:var(--font-mono);
      padding:0.1rem 0.4rem; border:1px solid; border-radius:999px; }
    .tly-like  { background:#1e4d18; color:#bfe89f; border-color:#3b6e3b; }
    .tly-maybe { background:#3a3110; color:#f0d27a; border-color:var(--gold-deep); }
    .tly-no    { background:#46211b; color:#eaa091; border-color:#5a2e28; }
    .ngsec { margin-bottom:0.5rem; }
    .snav__lnk { display:block; color:var(--gold-soft); text-decoration:none;
      padding:0.2rem 0.35rem; border-radius:4px; font-size:0.74rem;
      font-weight:700; letter-spacing:0.02em; }
    .snav__lnk:hover { color:var(--gold); background:var(--bg-elev);
      text-decoration:none; }
    .chips { display:flex; flex-wrap:wrap; gap:0.16rem;
      padding:0.18rem 0 0.1rem 0.3rem; }
    .vchip { font-size:0.58rem; font-family:var(--font-mono);
      color:var(--text-faint); background:#16181d;
      border:1px solid var(--border); border-radius:4px;
      padding:0.05rem 0.28rem; text-decoration:none; white-space:nowrap; }
    .vchip:hover { color:var(--gold); border-color:var(--gold-deep);
      text-decoration:none; }
    .vchip--lock { color:#9fd07f; border-color:#3b6e3b; background:#16290f; }
    .vchip.v-like  { background:#1e4d18; color:#bfe89f; border-color:#3b6e3b; }
    .vchip.v-maybe { background:#3a3110; color:#f0d27a; border-color:var(--gold-deep); }
    .vchip.v-no    { background:#46211b; color:#eaa091; border-color:#5a2e28; }
    .rmain { width:100%; }
    .gal { margin-top:0.6rem; }
    .gal > summary { cursor:pointer; font-size:0.78rem; color:var(--gold-soft);
      font-family:var(--font-ui); padding:0.25rem 0; user-select:none; }
    .gal > summary:hover { color:var(--gold); }
    .gal__grid { display:grid; gap:0.6rem; margin-top:0.5rem;
      grid-template-columns:repeat(6,1fr); }
    @media (max-width:760px){ .gal__grid{ grid-template-columns:1fr 1fr 1fr; } }
    .gal__cell { display:block; border-radius:4px; overflow:hidden;
      border:1px solid var(--border-strong); }
    .gal__cell:hover { border-color:var(--gold); }
    .gal__grid img { width:100%; height:auto; display:block; }
    .cap { display:grid; grid-template-columns:1fr 1fr 1fr;
      background:#0e0f12; font-size:0.6rem; }
    .cap span { display:flex; flex-direction:column; align-items:center;
      padding:0.16rem 0; border-right:1px solid var(--border);
      color:var(--text-soft); }
    .cap span:last-child { border-right:0; }
    .cap i { font-style:normal; font-size:0.5rem; color:var(--text-dim);
      text-transform:uppercase; }
    .cap b { color:var(--text); font-size:0.76rem; }
    .note { font-size:0.8rem; color:var(--text-faint); line-height:1.55;
      max-width:88ch; margin-top:1.6rem; }
  </style>

  <script is:inline>
    (function(){
      var KEY='ow_votes_r2';
      var votes={}; try{ votes=JSON.parse(localStorage.getItem(KEY)||'{}'); }catch(e){}
      function paint(){
        var cnt=0, total=0, t={like:0,maybe:0,no:0};
        document.querySelectorAll('.vote').forEach(function(v){
          total++;
          var s=v.getAttribute('data-slug');
          if(votes[s]){ cnt++; if(t[votes[s]]!=null) t[votes[s]]++; }
          v.querySelectorAll('button').forEach(function(b){
            b.classList.toggle('on', votes[s]===b.getAttribute('data-v'));
          });
        });
        document.querySelectorAll('.vchip[data-slug]').forEach(function(ch){
          var s=ch.getAttribute('data-slug');
          ch.classList.remove('v-like','v-maybe','v-no');
          if(votes[s]) ch.classList.add('v-'+votes[s]);
        });
        var vc=document.getElementById('vc'); if(vc) vc.textContent=cnt;
        ['like','maybe','no'].forEach(function(k){
          var e=document.getElementById('t-'+k); if(e) e.textContent=t[k];
        });
        var ad=document.getElementById('alldone');
        if(ad) ad.hidden=!(total>0 && cnt===total);
      }
      document.querySelectorAll('.vote button').forEach(function(b){
        b.addEventListener('click',function(){
          var s=b.parentElement.getAttribute('data-slug');
          var val=b.getAttribute('data-v');
          if(votes[s]===val){ delete votes[s]; } else { votes[s]=val; }
          localStorage.setItem(KEY,JSON.stringify(votes)); paint();
        });
      });
      paint();
      document.getElementById('copyv').addEventListener('click',function(){
        var by={like:[],maybe:[],no:[]};
        document.querySelectorAll('.cfg[data-slug]').forEach(function(c){
          var s=c.getAttribute('data-slug'), v=votes[s];
          if(by[v]) by[v].push(s);
        });
        var tot=by.like.length+by.maybe.length+by.no.length;
        var lines=['OW-VOTES-R2 v1','n: '+tot];
        ['like','maybe','no'].forEach(function(k){
          if(by[k].length) lines.push(k+': '+by[k].sort().join(',')); });
        lines.push('OW-VOTES-R2 END');
        navigator.clipboard.writeText(lines.join('\n')).then(function(){
          var b=document.getElementById('copyv'); var o=b.textContent;
          b.textContent='✓ copied!'; setTimeout(function(){b.textContent=o;},1500);
        });
      });
    })();
  </script>
</Base>
