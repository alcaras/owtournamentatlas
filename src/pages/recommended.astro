---
import Base from '../layouts/Base.astro';
import dist from '../data/atlas-dist.json';
import gensData from '../data/gens.json';
import tour from '../data/tournament-games.json';
const baseUrl = import.meta.env.BASE_URL;

const genMap: Record<string, any> = {};
for (const gn of (gensData as any).gens)
  genMap[gn.id] = { sites: gn.sites, land: gn.land, conn: gn.conn };
const idFromImg = (slug: string, p: string) => {
  const m = p.match(/seed-(\d+)/); return `${slug}-s${m ? m[1] : 1}`;
};
const gslug = (s: string) => 'g-' + s.toLowerCase().replace(/[^a-z0-9]+/g, '-');

const byGroup: Record<string, any[]> = {};
for (const c of dist.configs) (byGroup[c.group] ??= []).push(c);
const groups = dist.groups.filter((g: string) => byGroup[g]);

// no pass / no bands — just the distribution. connected% is the one gate.
const connClass = (p: number) => p >= 95 ? 'g' : p >= 75 ? 'o' : 'n';
const D = (o: any) => o == null ? '<td class="dash">—</td><td class="dash">—</td><td class="dash">—</td><td class="dash">—</td>'
  : `<td><b>${o.mean}</b> <span class="sd">±${o.sd}</span></td>`
  + `<td>${o.med}</td>`
  + `<td class="mono">${o.p10}–${o.p90}</td>`
  + `<td class="mono dim">${o.min}–${o.max}</td>`;
const N = dist.configs[0]?.n ?? 0;
const pill = (label: string, o: any) => o == null
  ? `<div class="pill"><div class="pill__l">${label}</div><div class="pill__v dash">—</div></div>`
  : `<div class="pill"><div class="pill__l">${label}</div>`
    + `<div class="pill__v"><b>${o.mean}</b> <span class="pm">±${o.sd}</span></div>`
    + `<div class="pill__r">min ${o.min} · p10 ${o.p10} · `
    + `<b>med ${o.med}</b> · p90 ${o.p90} · max ${o.max}</div></div>`;
---
<Base title="Map Distributions">
  <p class="lede">
    What each map setting actually produces over {N} blind random seeds —
    the full distribution, not a pass/fail. We don't screen or reject
    maps; these numbers tell you what you'll typically get and how wide
    the spread is. <b>p10–p90</b> is the typical range (9 in 10 maps);
    <b>min–max</b> is the worst observed. The only hard gate is
    <b>land-connected %</b> — the one true reroll trigger. Distances use
    the corrected even-r model with symmetric capitals.
  </p>

  <div class="legend">
    <span><span class="k cap"></span> capital (pink star)</span>
    <span><span class="k city"></span> city site (pink dot)</span>
    <span class="legnote">pointy-top hex, even-r (game-matched) ·
      <a href={`${baseUrl}calibration`}>{tour.count} real games →</a></span>
  </div>

  <nav class="snav" id="snav">
    <button id="copyv" class="snav__cv">⬇ COPY VOTES</button>
    <div class="snav__c">voted <b id="vc">0</b> / {dist.configCount}</div>
    <div class="snav__t">Map scripts</div>
    {groups.map((g: string) => (
      g === 'DOTA' ? (
        <>
          <a href={`#${gslug(g)}`}>{g}</a>
          {[...new Set(byGroup['DOTA'].map((c: any) => c.variant))].map((v: any) => {
            const first = byGroup['DOTA'].find((c: any) => c.variant === v);
            return <a class="sub" href={`#cfg-${first.slug}`}>{v}</a>;
          })}
        </>
      ) : <a href={`#${gslug(g)}`}>{g}</a>
    ))}
  </nav>

  <div class="rmain">
    {groups.map((g: string) => (
    <section class="grp" id={gslug(g)}>
      <h2 class="grp__h">{g}</h2>
      {byGroup[g].map((c: any) => (
        <div class="cfg" id={`cfg-${c.slug}`} data-slug={c.slug} data-label={c.label}
             data-sites={c.dist.sites?.mean ?? ''}
             data-land={c.dist.land?.mean ?? ''}>
          <div class="cfg__hd">
            <span class="cfg__name">{c.group}{c.variant ? ` · ${c.variant}` : ''}</span>
            <span class="cfg__chips">
              {c.setting.split(' · ').map((p: string) => (
                <span class="ch">{p}</span>
              ))}
              {c.tip && <span class="ch tip">{c.tip}</span>}
            </span>
            <span class="vote" data-slug={c.slug}>
              <button data-v="like">👍 like</button>
              <button data-v="maybe">🤔 maybe</button>
              <button data-v="no">👎 no</button>
            </span>
          </div>
          <div class="cfg__body">
            <div class="pills">
              <div class={'pill conn-' + connClass(c.connPct)}>
                <div class="pill__l">City sites</div>
                <div class="pill__v"><b>{c.dist.sites?.mean ?? '—'}</b> <span class="pm">±{c.dist.sites?.sd ?? 0}</span></div>
                <div class="pill__r">min {c.dist.sites?.min} · p10 {c.dist.sites?.p10} · <b>med {c.dist.sites?.med}</b> · p90 {c.dist.sites?.p90} · max {c.dist.sites?.max}</div>
              </div>
              <div class="pill">
                <div class="pill__l">Land hex distance</div>
                {c.dist.land ? (<>
                  <div class="pill__v"><b>{c.dist.land.mean}</b> <span class="pm">±{c.dist.land.sd}</span></div>
                  <div class="pill__r">min {c.dist.land.min} · p10 {c.dist.land.p10} · <b>med {c.dist.land.med}</b> · p90 {c.dist.land.p90} · max {c.dist.land.max}</div>
                </>) : <div class="pill__v dash">—</div>}
              </div>
              <div class={'pill ' + connClass(c.connPct) + '-bg'}>
                <div class="pill__l">Land connected</div>
                <div class="pill__v"><b>{c.connPct}</b><span class="pm">%</span></div>
                <div class="pill__r">of {c.n} maps</div>
              </div>
            </div>
            <details class="gal" open>
              <summary>{c.imgs.length} generated maps</summary>
              <div class="gal__grid">
                {c.imgs.map((p: string) => {
                  const id = idFromImg(c.slug, p);
                  const gm = genMap[id] || {};
                  return (
                    <a class="gal__cell" href={`${baseUrl}gen/${id}`}>
                      <img src={`${baseUrl}img/${p}`} loading="lazy"
                           alt={`${c.group} sample`} />
                      <div class={'cnbar ' + (gm.conn ? 'ok' : 'no')}>
                        {gm.conn ? 'LAND-CONNECTED' : 'NO LAND CONNECTION'}</div>
                      <div class="cap">
                        <span><i>city sites</i><b>{gm.sites ?? '—'}</b></span>
                        <span><i>land hex</i><b>{gm.land ?? '—'}</b></span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </details>
          </div>
        </div>
      ))}
    </section>
    ))}
    </div>

  <p class="note">
    {dist.configCount} configs × {N} seeds. No pass/fail and no fixed
    band — pick the targets you want and read them off the distribution.
    Capital distance is symmetric (player&nbsp;1's placed tile reflected
    for player&nbsp;2, as Old World does fair MP). Land path = walkable
    BFS (water/mountain impassable); Scout = orders for a move-3 Scout
    capital→capital; Crow = even-r hex ignoring terrain. Generated
    headless from owmapgen.
  </p>

  <style>
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:80ch; margin:0.6rem 0 1rem; }
    .legend { display:flex; flex-wrap:wrap; gap:1.1rem; align-items:center;
      font-size:0.78rem; color:var(--text-soft); background:var(--bg-elev);
      border:1px solid var(--border); border-radius:6px;
      padding:0.6rem 0.9rem; margin-bottom:1.6rem; }
    .legend .k { display:inline-block; vertical-align:-1px; margin-right:0.3rem; }
    .k.cap { width:0; height:0; border-left:7px solid transparent;
      border-right:7px solid transparent; border-bottom:12px solid #ff2daa;
      filter:drop-shadow(0 0 1px #fff); }
    .k.city { width:11px; height:11px; border-radius:50%;
      background:#ff2daa; border:1px solid #2a0a1c; }
    .legnote { color:var(--text-faint); margin-left:auto; }
    .grp { margin-bottom:2.2rem; }
    .grp__h { font-size:1.45rem; color:var(--gold); border-bottom:1px solid
      var(--gold-deep); padding-bottom:0.3rem; margin-bottom:0.7rem; }
    .cfg { background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.8rem 1rem; margin-bottom:0.8rem; }
    .cfg__hd { display:flex; align-items:baseline; gap:0.8rem; flex-wrap:wrap; }
    .cfg__name { font-family:var(--font-display); font-weight:700;
      font-size:1.18rem; color:var(--text); }
    .conn { font-family:var(--font-ui); font-weight:700; font-size:0.74rem;
      padding:0.14rem 0.55rem; border-radius:999px; border:1px solid; }
    .conn.g { color:#9fd07f; border-color:#3b6e3b; background:#16290f; }
    .conn.o { color:#e0c061; border-color:var(--gold-deep); background:#231f0d; }
    .conn.n { color:#d08070; border-color:#5a2e28; background:#2a1512; }
    .cfg__chips { display:inline-flex; gap:0.3rem; flex-wrap:wrap; }
    .ch { font-size:0.66rem; font-family:var(--font-mono);
      color:var(--text-soft); background:#0e0f12;
      border:1px solid var(--border-strong); border-radius:4px;
      padding:0.08rem 0.4rem; }
    .ch.tip { color:var(--gold-soft); border-color:var(--gold-deep); }
    .rmain { width:100%; }
    .snav { position:fixed; left:max(8px, calc((100vw - 1180px)/2 - 168px));
      top:84px; width:160px; display:flex; flex-direction:column;
      gap:0.12rem; font-size:0.78rem; max-height:calc(100vh - 100px);
      overflow:auto; z-index:20; }
    @media (max-width:1320px){ .snav{ left:8px; } }
    @media (max-width:980px){ .snav{ position:static; width:auto;
      flex-flow:row wrap; max-height:none; margin-bottom:1rem; } }
    .snav__cv { background:#231f0d; color:var(--gold); cursor:pointer;
      border:1px solid var(--gold-deep); border-radius:7px;
      padding:0.5rem 0.6rem; font-weight:700; font-size:0.86rem;
      margin-bottom:0.35rem; }
    .snav__cv:hover { background:#2e2810; }
    .snav__c { font-size:0.74rem; color:var(--text-soft);
      margin-bottom:0.5rem; } .snav__c b { color:var(--gold); }
    .snav__t { font-size:0.6rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-dim); margin-bottom:0.2rem; }
    .snav a { color:var(--text-soft); text-decoration:none;
      padding:0.1rem 0.3rem; border-radius:4px; }
    .snav a.sub { padding-left:0.9rem; font-size:0.72rem;
      color:var(--text-faint); }
    .snav a:hover { color:var(--gold); background:var(--bg-elev); }
    .pill.g-bg { border-color:#3b6e3b; }
    .pill.o-bg { border-color:var(--gold-deep); }
    .pill.n-bg { border-color:#5a2e28; }
    .cnbar { text-align:center; font-weight:700; font-size:0.74rem;
      letter-spacing:0.06em; padding:0.28rem 0; }
    .cnbar.ok { background:#1e4d18; color:#bfe89f; }
    .cnbar.no { background:#46211b; color:#eaa091; }
    .cap { display:grid; grid-template-columns:1fr 1fr;
      background:#0e0f12; font-size:0.72rem; }
    .cap span { display:flex; flex-direction:column; align-items:center;
      padding:0.22rem 0; border-right:1px solid var(--border); color:var(--text-soft); }
    .cap span:last-child { border-right:0; }
    .cap i { font-style:normal; font-size:0.58rem; color:var(--text-dim);
      text-transform:uppercase; letter-spacing:0.06em; }
    .cap b { color:var(--text); font-size:0.92rem; }
    .cfg__body { margin-top:0.6rem; }
    .pills { display:flex; flex-wrap:wrap; gap:0.8rem; }
    .pill { flex:1 1 280px; background:#16181d;
      border:1px solid var(--gold-deep); border-radius:8px;
      padding:0.6rem 0.9rem; }
    .pill__l { font-size:0.66rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-dim); }
    .pill__v { font-size:2.9rem; font-family:var(--font-display);
      font-weight:700; color:var(--gold); line-height:1.1;
      margin:0.1rem 0 0.15rem; }
    .pill__v .pm { font-size:1.05rem; color:var(--text-faint);
      font-family:var(--font-ui); font-weight:400; }
    .pill__v.dash { color:var(--text-dim); }
    .pill__r { font-size:0.74rem; color:var(--text-faint);
      font-family:var(--font-mono); margin-top:0.15rem; }
    .pill__r b { color:var(--text-soft); }
    .dt { border-collapse:collapse; font-size:0.84rem; min-width:440px; }
    .dt thead th { font-family:var(--font-ui); font-size:0.56rem;
      letter-spacing:0.13em; text-transform:uppercase; color:var(--text-dim);
      font-weight:600; text-align:left; padding:0.25rem 0.9rem 0.25rem 0;
      border-bottom:1px solid var(--border-strong); }
    .dt td { padding:0.26rem 0.9rem 0.26rem 0;
      border-bottom:1px solid var(--border); white-space:nowrap; }
    .dt td.m { color:var(--text-soft); }
    .dt td b { color:var(--text); }
    .sd { color:var(--text-faint); font-size:0.82em; }
    .mono { font-family:var(--font-mono); font-size:0.82em; }
    .dim { color:var(--text-faint); }
    .dash { color:var(--text-dim); }
    .aux { font-size:0.78rem; color:var(--text-faint); margin:0.5rem 0; }
    .aux b { color:var(--text-soft); }
    .gal > summary { cursor:pointer; font-size:0.8rem; color:var(--gold-soft);
      font-family:var(--font-ui); padding:0.3rem 0; user-select:none; }
    .gal > summary:hover { color:var(--gold); }
    .gal__grid { display:grid; gap:0.6rem; margin-top:0.5rem;
      grid-template-columns:repeat(3,1fr); }
    @media (max-width:760px){ .gal__grid{ grid-template-columns:1fr 1fr; } }
    .gal__cell { display:block; border-radius:4px; overflow:hidden;
      border:1px solid var(--border-strong); }
    .gal__cell:hover { border-color:var(--gold); }
    .gal__grid img { width:100%; height:auto; display:block;
      border-radius:3px; border:1px solid var(--border-strong);
      image-rendering:auto; }
    .note { font-size:0.8rem; color:var(--text-faint); line-height:1.5;
      max-width:84ch; margin-top:1.6rem; }
    .bar { position:sticky; top:0; z-index:5; display:flex;
      flex-wrap:wrap; align-items:center; gap:0.7rem 1rem;
      background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.6rem 0.9rem; margin:0 0 1.4rem;
      font-size:0.82rem; }
    .bar__n { color:var(--text-soft); } .bar__n b { color:var(--gold); }
    .bar label { color:var(--text-soft); }
    .bar input { width:3.6rem; background:#0e0f12; color:var(--text);
      border:1px solid var(--border-strong); border-radius:4px;
      padding:0.15rem 0.3rem; font-size:0.82rem; }
    .btn { background:#0e0f12; color:var(--text-soft); cursor:pointer;
      border:1px solid var(--border-strong); border-radius:5px;
      padding:0.25rem 0.6rem; font-size:0.78rem; }
    .btn:hover { color:var(--gold); border-color:var(--gold-deep); }
    .btn.big { margin-left:auto; font-weight:700; font-size:0.86rem;
      padding:0.4rem 0.9rem; color:var(--gold); border-color:var(--gold-deep);
      background:#231f0d; }
    .vote { display:inline-flex; gap:0.4rem; margin-left:auto; }
    .vote button { background:#1b1d23; color:var(--text-soft);
      border:1px solid var(--border-strong); border-radius:7px;
      padding:0.34rem 0.8rem; font-size:0.85rem; font-weight:600;
      cursor:pointer; transition:transform .06s; }
    .vote button:hover { color:var(--text); transform:translateY(-1px); }
    .vote button.on[data-v="like"]  { background:#1e4d18; color:#bfe89f; border-color:#3b6e3b; box-shadow:0 0 0 1px #3b6e3b; }
    .vote button.on[data-v="maybe"] { background:#3a3110; color:#f0d27a; border-color:var(--gold-deep); box-shadow:0 0 0 1px var(--gold-deep); }
    .vote button.on[data-v="no"]    { background:#46211b; color:#eaa091; border-color:#5a2e28; box-shadow:0 0 0 1px #5a2e28; }
    .cfg.hide { display:none; }
  </style>

  <script is:inline>
    (function(){
      var KEY='ow_votes_v1';
      var votes={}; try{ votes=JSON.parse(localStorage.getItem(KEY)||'{}'); }catch(e){}
      function paint(){
        var cnt=0;
        document.querySelectorAll('.vote').forEach(function(v){
          var s=v.getAttribute('data-slug');
          if(votes[s]) cnt++;
          v.querySelectorAll('button').forEach(function(b){
            b.classList.toggle('on', votes[s]===b.getAttribute('data-v'));
          });
        });
        var vc=document.getElementById('vc'); if(vc) vc.textContent=cnt;
      }
      document.querySelectorAll('.vote button').forEach(function(b){
        b.addEventListener('click',function(){
          var s=b.parentElement.getAttribute('data-slug');
          var val=b.getAttribute('data-v');
          if(votes[s]===val){ delete votes[s]; } else { votes[s]=val; }
          localStorage.setItem(KEY,JSON.stringify(votes)); paint();
        });
      });
      paint();
      document.getElementById('copyv').addEventListener('click',function(){
        var by={like:[],maybe:[],no:[]};
        document.querySelectorAll('.cfg').forEach(function(c){
          var s=c.getAttribute('data-slug'), l=c.getAttribute('data-label');
          if(votes[s]) by[votes[s]].push(l);
        });
        var txt='OW map votes\\n'
          +'\\n👍 LIKE ('+by.like.length+')\\n'+(by.like.join('\\n')||'—')
          +'\\n\\n🤷 MAYBE ('+by.maybe.length+')\\n'+(by.maybe.join('\\n')||'—')
          +'\\n\\n👎 PLS NO ('+by.no.length+')\\n'+(by.no.join('\\n')||'—');
        navigator.clipboard.writeText(txt).then(function(){
          var b=document.getElementById('copyv'); var o=b.textContent;
          b.textContent='✓ copied!'; setTimeout(function(){b.textContent=o;},1500);
        });
      });
    })();
  </script>
</Base>
