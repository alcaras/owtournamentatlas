---
import Base from '../layouts/Base.astro';
import opt from '../data/options.json';
import tour from '../data/tournament-games.json';
import recs from '../data/recommendations.json';
const baseUrl = import.meta.env.BASE_URL;

// group option rows by script, preserve config order
const order = ["DOTA","Continent","Coastal Rain Basin","Inland Sea","Donut",
  "Archipelago","Arid Plateau","Desert","Hardwood Forest","Mountain Pass"];
const byScript: Record<string, any[]> = {};
for (const r of opt.rows) (byScript[r.script] ??= []).push(r);
const scripts = order.filter(s => byScript[s]);

const D = (o: any) => o == null ? '—'
  : `${o.mean.toFixed(0)} <span class="dim">[${o.min}–${o.max}]</span>`;
// ranking comes from the corrected (symmetric-capital) rec sweep
const ranked = [...recs.maps].sort((a:any,b:any)=>
  b.okPct-a.okPct || b.critPct-a.critPct);
// knob tables (below) still read the option sweep; highlight best row
const best: Record<string, any> = {};
for (const s of scripts) {
  best[s] = [...byScript[s]].sort((a,b)=>
    b.passPct-a.passPct || b.landConnPct-a.landConnPct ||
    Math.abs(a.sites.mean-20)-Math.abs(b.sites.mean-20))[0];
}
---
<Base title="Recommended Settings">
  <p class="lede">
    The <i>ideal map</i> we tune settings toward: land-connected,
    18–22 city sites, 45–65-hex land distance (15–25 sites acceptable).
    We don't screen or reject maps — these are targets, not gates.
    <b>% meet criteria</b> = share of blind maps hitting the ideal band;
    <b>acceptable</b> = the looser 15–25-site band. n=10/config.
    Distances use the corrected even-r model with symmetric capitals
    (a prior bug placed the two capitals non-symmetrically — now fixed).
  </p>

  <section class="pool">
    <h2 class="pool__h">Scripts ranked by how often they hit criteria</h2>
    <div class="cards">
      {ranked.slice(0,6).map((m:any) => (
        <div class="card">
          <div class="card__t">{m.label}</div>
          <div class="card__cfg">{m.setting}{m.tip ? ` · ${m.tip}` : ''}</div>
          <div class="card__m">
            <b class={m.critPct>=70?'g':m.critPct>=30?'o':'n'}>{m.critPct}% criteria</b> ·
            {m.okPct}% acceptable · sites {m.sites} · land {m.land}
          </div>
        </div>
      ))}
    </div>
    <p class="note">
      Note: with symmetric capitals corrected, no open script lands in
      the tight ideal band on every blind map (the earlier
      "DOTA = 100%" result was an artifact of the capital-placement
      bug — DOTA ultrawide actually runs ~68 land, just over the 65
      cap). Inland Sea / Wetlands hit the band most often. This is why
      we treat the bands as targets and only reroll on a true failure
      (no land connection). Historically the tournament used Coastal
      Rain Basin, Continent and Inland Sea ({tour.count} games on the
      <a href={`${import.meta.env.BASE_URL}calibration`}>calibration</a> page).
      The per-map knob tables below are being regenerated on the fixed
      binary.
    </p>
  </section>

  <h2 class="sec">Recommended setting per map + {recs.N} hex previews</h2>
  <p class="note">Each card = the recommended config for that script.
    Capitals are the big <b>player-colored stars</b> (red = player 1,
    blue = player 2); gold = city sites, red dots = tribe camps. Real
    pointy-top hex (even-r, game-matched).</p>
  {recs.maps.map((m:any) => (
    <section class="rec">
      <header class="rec__hd">
        <h3 class="rec__name">{m.label}</h3>
        <span class={'rec__pct ' + (m.critPct >= 70 ? 'g' : m.critPct >= 30 ? 'o' : 'n')}>
          {m.critPct}% meet criteria
          <span class="rec__ok">· {m.okPct}% acceptable · n={m.n}</span>
        </span>
      </header>
      <div class="rec__cfg">
        <b>Settings:</b> {m.setting}
        {m.options && m.options[0] !== '(defaults)' && <span> · <b>option:</b> {m.options.join(', ')}</span>}
        {m.tip && <span> · {m.tip}</span>}
      </div>
      <div class="rec__stats">
        sites <b>{m.sites}</b> · capital crow <b>{m.crow}</b> · land path
        <b>{m.land}</b> · land-connected <b>{m.landConnPct}%</b>
      </div>
      {m.previews && m.previews.length > 0 && (
        <div class="rec__gal">
          {m.previews.map((p:string) => (
            <img src={`${baseUrl}img/${p}`} loading="lazy" alt={`${m.label} sample`} />
          ))}
        </div>
      )}
    </section>
  ))}

  <h2 class="sec">Per-map: the knob that moves land-connection / distance</h2>
  {scripts.map(s => (
    <section class="grp">
      <h3 class="grp__h">{s} <span class="grp__b">{byScript[s][0].base} · {byScript[s][0].axis}</span></h3>
      <div class="tscroll">
        <table class="tbl">
          <thead><tr>
            <th>Variant</th><th>Land-conn%</th><th>Pass%</th>
            <th>City sites</th><th>Crow</th><th>Land path</th><th>Scout</th>
          </tr></thead>
          <tbody>
            {byScript[s].map((r:any) => (
              <tr class={r === best[s] ? 'is-best' : ''}>
                <td><b>{r.variant}</b></td>
                <td class={r.landConnPct < 100 ? 'bad' : ''}>{r.landConnPct}%</td>
                <td class={r.passPct >= 100 ? 'good' : r.passPct >= 30 ? '' : 'bad'}>{r.passPct}%</td>
                <td class="mono" set:html={D(r.sites)} />
                <td class="mono" set:html={D(r.crow)} />
                <td class="mono" set:html={D(r.landPath)} />
                <td class="mono">{r.scout?.mean ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ))}

  <p class="note" style="margin-top:1.4rem;">
    Inland Sea &amp; Wetlands have no connection/distance map-option (base
    only). Distances even-r (game-verified). Pass band: land 40–80, sites
    12–28, land-connected — applied to every seed, not the average.
  </p>

  <style>
    .lede { font-family: var(--font-display); font-style: italic; font-size: 1.05rem;
      line-height: 1.55; color: var(--text-soft); max-width: 76ch; margin: 0.6rem 0 1.4rem; }
    .pool { background: var(--bg-elev); border: 1px solid var(--gold-deep);
      border-radius: 6px; padding: 1rem 1.2rem; margin-bottom: 2rem; }
    .pool__h { font-size: 1.2rem; color: var(--gold); margin-bottom: 0.7rem; }
    .cards { display:flex; flex-wrap:wrap; gap:0.7rem; }
    .card { background:#16181d; border:1px solid var(--gold-deep); border-radius:5px;
      padding:0.7rem 0.9rem; min-width:230px; }
    .card__t { font-family:var(--font-display); font-weight:700; font-size:1.15rem; color:var(--gold); }
    .card__cfg { font-size:0.82rem; color:var(--text-soft); margin:0.15rem 0 0.3rem; }
    .card__m { font-size:0.78rem; color:var(--text-faint); }
    .sec { font-size:1.35rem; border-bottom:1px solid var(--gold-deep);
      padding-bottom:0.3rem; margin:1.6rem 0 0.6rem; }
    .grp { margin-bottom:1.4rem; }
    .grp__h { font-size:1.1rem; } .grp__b { font-size:0.74rem; color:var(--text-faint); font-family:var(--font-mono); }
    .tscroll { overflow-x:auto; }
    .tbl { width:100%; border-collapse:collapse; font-size:0.86rem; margin-top:0.3rem; }
    .tbl thead th { font-family:var(--font-ui); font-size:0.56rem; letter-spacing:0.13em;
      text-transform:uppercase; color:var(--text-dim); font-weight:600; text-align:left;
      padding:0.3rem 0.6rem; border-bottom:1px solid var(--border-strong); white-space:nowrap; }
    .tbl td { padding:0.34rem 0.6rem; border-bottom:1px solid var(--border); white-space:nowrap; }
    .tbl tr.is-best td { background:#16290f; }
    .mono { font-family:var(--font-mono); font-size:0.82em; }
    .dim { color:var(--text-faint); } .good { color:#7fb069; font-weight:600; }
    .bad { color:#b06a5f; font-weight:600; }
    .note { font-size:0.82rem; color:var(--text-faint); line-height:1.5; max-width:82ch; }
    .rec { background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.9rem 1.1rem; margin-bottom:1rem; }
    .rec__hd { display:flex; align-items:baseline; gap:0.8rem; flex-wrap:wrap; }
    .rec__name { font-family:var(--font-display); font-weight:700; font-size:1.25rem; color:var(--text); }
    .rec__pct { font-size:0.78rem; font-family:var(--font-ui); font-weight:700;
      letter-spacing:0.04em; padding:0.16rem 0.6rem; border-radius:999px; border:1px solid; }
    .rec__pct.g { color:#9fd07f; border-color:#3b6e3b; background:#16290f; }
    .rec__pct.o { color:#e0c061; border-color:var(--gold-deep); background:#231f0d; }
    .rec__pct.n { color:#d08070; border-color:#5a2e28; background:#2a1512; }
    .rec__ok { font-weight:400; font-size:0.66rem; color:var(--text-faint);
      letter-spacing:0.02em; }
    .rec__cfg { font-size:0.9rem; color:var(--text-soft); margin:0.4rem 0 0.2rem; }
    .rec__cfg b, .rec__stats b { color:var(--text); }
    .rec__stats { font-size:0.82rem; color:var(--text-faint); margin-bottom:0.6rem; }
    .rec__gal { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:0.4rem; }
    .rec__gal img { width:100%; height:auto; display:block; border-radius:3px;
      border:1px solid var(--border); image-rendering:auto; }
  </style>
</Base>
