---
import Base from '../../layouts/Base.astro';
import data from '../../data/oneoffs.json';
const baseUrl = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const d = data as any;
  return d.maps.map((g: any) => ({
    params: { slug: g.slug }, props: { g, resTax: d.resTax } }));
}
const { g, resTax } = Astro.props as { g: any; resTax: any };
const have = (n: string): number => (g.resources || {})[n] || 0;
const groups: [string, string[]][] = [
  ['Luxury', resTax.lux], ['Strategic', resTax.strategic],
  ['Food', resTax.food]];
const nice = (n: string) => n.replace(/_/g, ' ');
---
<Base title={`One-off · ${g.matchup}`}>
  <p class="back"><a href={`${baseUrl}oneoff`}>← all one-offs</a></p>
  <p class="lede">
    <b>{g.matchup}</b> · <span class="mono">{g.file}</span>. High-res
    tactical view — rivers (blue) and game resource icons shown; pink
    stars = capitals, pink dots = city sites. Even-r distance model.
  </p>

  <div class="grid">
    <figure class="mapfig">
      <img src={`${baseUrl}img/${g.imgPretty ?? g.img}`} alt={`${g.matchup} map`} />
      <figcaption>
        {g.script} · {g.size} · {g.aspect} — {g.players?.[0]} ▪ {g.players?.[1]}
        {g.imgPretty && <span> · <a href={`${baseUrl}img/${g.img}`}>mini</a></span>}
      </figcaption>
    </figure>

    <div class="stats">
      <h2>Capital distance</h2>
      <table class="kv">
        <tr><td>Land-connected</td><td class={g.landConnected ? 'good' : 'bad'}>
          {g.landConnected ? 'YES' : 'NO'}</td></tr>
        <tr><td>Crow (hex)</td><td><b>{g.crow}</b></td></tr>
        <tr><td>Land path</td><td><b>{g.land ?? '—'}</b></td></tr>
        <tr><td>Sea path</td><td>{g.sea ?? '—'}</td></tr>
        <tr><td>Scout orders (move 3)</td><td><b>{g.scout ?? '—'}</b></td></tr>
        <tr><td>Slinger — land</td><td>{g.slingerLand ?? '—'}</td></tr>
        <tr><td>Slinger — sea</td><td>{g.slingerSea ?? '—'}</td></tr>
        <tr><td>Slinger — Hatti (ign. hill)</td><td>{g.slingerHatti ?? '—'}</td></tr>
        <tr><td>Capitals @ tiles</td><td class="mono">
          {g.caps?.[0]?.join(',')} · {g.caps?.[1]?.join(',')}</td></tr>
      </table>

      <h2>Map</h2>
      <table class="kv">
        <tr><td>City sites</td><td><b>{g.citySites}</b></td></tr>
        <tr><td>Founded cities</td><td>{g.cityCount}</td></tr>
        <tr><td>Tribes ({g.tribeCount})</td><td>{(g.tribes||[]).join(', ') || '—'}</td></tr>
        <tr><td>Ocean / forest</td><td>{g.oceanPct}% / {g.forestPct}%</td></tr>
        <tr><td>Hill / mountain</td><td>{g.hillPct}% / {g.mountainPct}%</td></tr>
        <tr><td>Resources</td><td>{g.resourceCount}</td></tr>
      </table>

      <h2>Yield tiles (best improvement)</h2>
      <table class="kv">
        <tr><td>6+ &nbsp;F·I·W·S</td><td class="mono">
          {g.yield6 ? `${g.yield6.food}·${g.yield6.iron}·${g.yield6.wood}·${g.yield6.stone}` : '—'}</td></tr>
        <tr><td>8+ &nbsp;F·I·W·S</td><td class="mono">
          {g.yield8 ? `${g.yield8.food}·${g.yield8.iron}·${g.yield8.wood}·${g.yield8.stone}` : '—'}</td></tr>
      </table>

      <h2>Resources <span class="rh">({g.resourceCount} total · grey = absent)</span></h2>
      {groups.map(([title, list]) => (
        <div class="resgrp">
          <div class="resgrp__t">{title}</div>
          <div class="reschips">
            {list.map((n) => {
              const c = have(n);
              return (
                <span class={'chip' + (c ? '' : ' off')}>
                  {nice(n)}{c ? <b> {c}</b> : null}
                </span>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>

  <p class="note">
    Stone counts include the Quarry +40%/adjacent-Mountain bonus. Land
    path = walkable BFS (water/mountain impassable); Scout = orders for a
    move-3 Scout capital→capital; Crow = even-r hex. Capital = each
    player's <i>original</i> founded capital.
  </p>

  <style>
    .back { font-size:0.8rem; margin:0 0 0.4rem; }
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:80ch; margin:0.2rem 0 1.4rem; }
    .grid { display:grid; grid-template-columns:minmax(420px,1.6fr) 1fr;
      gap:1.6rem; align-items:start; }
    @media (max-width:880px){ .grid{ grid-template-columns:1fr; } }
    .mapfig { margin:0; }
    .mapfig img { width:100%; height:auto; display:block; border-radius:5px;
      border:1px solid var(--border-strong); background:#0b0c0f; }
    .mapfig figcaption { font-size:0.76rem; color:var(--text-faint);
      font-family:var(--font-mono); margin-top:0.4rem; }
    .stats h2 { font-size:1.05rem; color:var(--gold); margin:1rem 0 0.3rem; }
    .stats h2:first-child { margin-top:0; }
    .kv { width:100%; border-collapse:collapse; font-size:0.86rem; }
    .kv td { padding:0.28rem 0.4rem; border-bottom:1px solid var(--border); }
    .kv td:first-child { color:var(--text-soft); }
    .kv td:last-child { text-align:right; }
    .kv b { color:var(--text); }
    .mono { font-family:var(--font-mono); font-size:0.86em; }
    .good { color:#9fd07f; font-weight:700; }
    .bad { color:#d08070; font-weight:700; }
    .rh { font-size:0.72rem; color:var(--text-faint); font-weight:400; }
    .resgrp { margin:0.4rem 0 0.6rem; }
    .resgrp__t { font-size:0.68rem; letter-spacing:0.12em;
      text-transform:uppercase; color:var(--text-dim);
      font-family:var(--font-ui); margin-bottom:0.3rem; }
    .reschips { display:flex; flex-wrap:wrap; gap:0.35rem; }
    .chip { font-size:0.74rem; background:var(--bg-elev);
      border:1px solid var(--gold-deep); border-radius:999px;
      padding:0.1rem 0.5rem; color:var(--text); }
    .chip b { color:var(--gold); }
    .chip.off { background:transparent; border-color:var(--border);
      color:var(--text-dim); opacity:0.55; }
    .note { font-size:0.8rem; color:var(--text-faint); line-height:1.5;
      max-width:84ch; margin-top:1.6rem; }
  </style>
</Base>
