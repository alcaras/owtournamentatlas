---
import Base from '../../layouts/Base.astro';
import data from '../../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const d = data as any;
  return d.gens.map((g: any) => ({
    params: { id: g.id }, props: { g, resTax: d.resTax } }));
}
const { g, resTax } = Astro.props as { g: any; resTax: any };
const have = (n: string): number => (g.resources || {})[n] || 0;
const nice = (n: string) => n.replace(/_/g, ' ');
const Y = g.yields || {};
const thr = ['5','6','7','8','9','10','11','12'];
---
<Base title={`Gen · ${g.label}`}>
  <p class="back"><a href={`${baseUrl}recommended`}>← all recommended</a></p>
  <p class="lede">
    <b>{g.label}</b> · seed {g.seed}. <span class="mono">{g.setting}</span>.
    <b>Hover a tile</b> for details; <b>hover/click a resource below</b>
    to light up every tile of it. Pink stars = capitals · pink dots =
    city sites · blue = rivers · faded grey = impassable/off-map.
    (<a href={`${baseUrl}img/${g.img}`} target="_blank" rel="noopener">static image ↗</a>)
  </p>

  <div id="mapwrap"><canvas id="cv"></canvas><div id="tip"></div></div>

  <h2 class="sec">Resources <span class="rh">(hover to highlight)</span></h2>
  <div id="respanel" class="respanel"></div>

  <h2 class="sec">Stats</h2>
  <div class="stats">
    <div class="col">
      <h3>Capital distance</h3>
      <table class="kv">
        <tr><td>Land-connected</td><td class={g.conn ? 'good' : 'bad'}>
          {g.conn ? 'YES' : 'NO'}</td></tr>
        <tr><td>Crow (hex)</td><td><b>{g.crow ?? '—'}</b></td></tr>
        <tr><td>Land path</td><td><b>{g.land ?? '—'}</b></td></tr>
        <tr><td>Sea path</td><td>{g.water ?? '—'}</td></tr>
        <tr><td>Scout orders</td><td><b>{g.scout ?? '—'}</b></td></tr>
        <tr><td>Slinger L/S/Hatti</td><td>
          {g.slLand ?? '—'}/{g.slSea ?? '—'}/{g.slHatti ?? '—'}</td></tr>
      </table>
    </div>
    <div class="col">
      <h3>Map</h3>
      <table class="kv">
        <tr><td>City sites</td><td><b>{g.sites ?? '—'}</b></td></tr>
        <tr><td>Playable tiles</td><td>{g.tiles ?? '—'}</td></tr>
        <tr><td>Land tiles</td><td><b>{g.landTiles ?? '—'}</b></td></tr>
        <tr><td>Ocean %</td><td>{g.oceanPct ?? '—'}%</td></tr>
        <tr><td>Tribes / Res</td><td>{g.tribes ?? '—'} / {g.res ?? '—'}</td></tr>
      </table>
    </div>
    <div class="col">
      <h3>Yield tiles ≥N <span class="rh">(hover a cell → highlight)</span></h3>
      <table class="kv yt">
        <tr><th>≥</th><th>Food</th><th>Iron</th><th>Stone</th><th>Wood</th></tr>
        {thr.map(k => { const y=Y[k]||{}; const N=parseInt(k)*10;
          return (
          <tr><td>{k}+</td>
            {['food','iron','stone','wood'].map(yk => (
              <td class="yc" data-y={yk} data-n={N}>{y[yk] ?? 0}</td>
            ))}
          </tr>
        ); })}
      </table>
    </div>
  </div>


  <style>
    .back { font-size:0.8rem; margin:0 0 0.4rem; }
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.02rem; line-height:1.55; color:var(--text-soft);
      max-width:90ch; margin:0.2rem 0 1.2rem; }
    #mapwrap { position:relative; width:100%; }
    #cv { width:100%; height:auto; display:block; border-radius:5px;
      border:1px solid var(--border-strong); background:#0b0c0f; }
    #tip { position:absolute; pointer-events:none; display:none; z-index:9;
      background:rgba(12,13,16,0.96); border:1px solid var(--gold-deep);
      border-radius:5px; padding:0.4rem 0.55rem; font-size:0.74rem;
      color:var(--text); font-family:var(--font-ui); white-space:nowrap;
      line-height:1.4; }
    #tip b { color:var(--gold); }
    .sec { font-size:1.15rem; color:var(--gold); border-bottom:1px solid
      var(--gold-deep); padding-bottom:0.25rem; margin:1.5rem 0 0.6rem; }
    .rh { font-size:0.72rem; color:var(--text-faint); font-weight:400; }
    .respanel { display:flex; flex-wrap:wrap; gap:0.3rem; }
    .rchip { display:inline-flex; align-items:center; gap:0.25rem;
      cursor:pointer; background:var(--bg-elev);
      border:1px solid var(--gold-deep); border-radius:999px;
      padding:0.08rem 0.5rem 0.08rem 0.28rem; font-size:0.74rem;
      color:var(--text); user-select:none; line-height:1.4; }
    .rchip img { width:14px; height:14px; display:block; }
    .rchip b { color:var(--gold); font-size:0.72rem; }
    .rchip:hover, .rchip.pin { border-color:var(--gold);
      background:#231f0d; color:var(--gold); }
    .expl { font-size:0.84rem; color:var(--text-soft); line-height:1.5;
      max-width:88ch; margin:0.2rem 0 0.7rem; }
    .expl b { color:#9fd07f; } .expl .dim, .dim { color:var(--text-dim); }
    .stats { display:grid; gap:1.4rem;
      grid-template-columns:repeat(3,minmax(0,1fr)); }
    @media (max-width:820px){ .stats{ grid-template-columns:1fr 1fr; } }
    @media (max-width:560px){ .stats{ grid-template-columns:1fr; } }
    .col { min-width:0; }
    .yt th { font-size:0.62rem; letter-spacing:0.05em; color:var(--text-dim);
      text-transform:uppercase; text-align:right; font-weight:600;
      padding:0.2rem 0.4rem; border-bottom:1px solid var(--border-strong); }
    .yt th:first-child { text-align:left; }
    .yt td { text-align:right; }
    .yt td.yc { cursor:crosshair; font-family:var(--font-mono);
      font-size:0.82em; }
    .yt td.yc:hover { background:#231f0d; color:var(--gold); }
    .stats h3 { font-size:0.98rem; color:var(--text); margin:0.6rem 0 0.25rem; }
    .col:first-child h3:first-child { margin-top:0; }
    .kv { width:100%; border-collapse:collapse; font-size:0.86rem; }
    .kv td { padding:0.26rem 0.4rem; border-bottom:1px solid var(--border); }
    .kv td:first-child { color:var(--text-soft); }
    .kv td:last-child { text-align:right; }
    .kv b { color:var(--text); }
    .mono { font-family:var(--font-mono); font-size:0.86em; }
    .good { color:#9fd07f; font-weight:700; }
    .bad { color:#d08070; font-weight:700; }
    .resgrp { margin:0.3rem 0 0.6rem; }
    .resgrp__t { font-size:0.66rem; letter-spacing:0.12em;
      text-transform:uppercase; color:var(--text-dim);
      font-family:var(--font-ui); margin-bottom:0.3rem; }
    .reschips { display:flex; flex-wrap:wrap; gap:0.35rem; }
    .chip { font-size:0.74rem; background:var(--bg-elev);
      border:1px solid var(--gold-deep); border-radius:999px;
      padding:0.1rem 0.5rem; color:var(--text); }
    .chip b { color:var(--gold); }
    .chip.off { background:transparent; border-color:var(--border);
      color:var(--text-dim); opacity:0.55; }
  </style>

  <script is:inline define:vars={{ gid: g.id, base: baseUrl }}>
    (function(){
      var TERR={WATER:[38,71,110],TEMPERATE:[104,138,74],LUSH:[74,110,56],
        ARID:[170,148,95],SAND:[206,184,120],MARSH:[96,110,80],
        TUNDRA:[200,205,210],URBAN:[150,128,116]};
      var ALIAS={marble:'stone',ore:'iron'};
      function tcol(n){ return TERR[n.toUpperCase().replace(/ /g,'_')]||[90,90,90]; }
      function lum(c){ return 0.299*c[0]+0.587*c[1]+0.114*c[2]; }
      var cv=document.getElementById('cv'), tip=document.getElementById('tip'),
          ctx=cv.getContext('2d'), S=11, HW=Math.sqrt(3)*S, VS=1.5*S, PAD=4,
          D=null, baseImg=null, icons={}, activeRes=null, pinRes=null;
      function cen(x,y){ return [x*HW+(y%2===0?HW/2:0)+HW/2+PAD, y*VS+S+PAD]; }
      function hexp(cx,cy,r){ ctx.beginPath();
        for(var i=0;i<6;i++){ var a=Math.PI/180*(60*i-90),
          px=cx+r*Math.cos(a),py=cy+r*Math.sin(a);
          i?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); }
      function slug(name){ var s=name.toLowerCase().replace(/ /g,'_');
        return ALIAS[s]||s; }
      function drawBase(){
        var W=D.w,H=D.h,Lt=D.L.terr,Lh=D.L.hgt,Lv=D.L.veg;
        ctx.fillStyle='#0b0c0f'; ctx.fillRect(0,0,cv.width,cv.height);
        // owmapgen tags ALL sea as HEIGHT_COAST; derive ocean vs coast
        // like the game: coast = water touching land, else ocean.
        function isWaterTile(j){ return (Lt[D.terr[j]]||'').toUpperCase()==='WATER'; }
        var oDXe=[0,1,1,1,0,-1],oDXo=[-1,0,1,0,-1,-1],oDY=[1,1,0,-1,-1,0];
        function touchesLand(x,y){
          for(var k=0;k<6;k++){ var nx=x+(y%2===0?oDXe:oDXo)[k], ny=y+oDY[k];
            if(nx<0||ny<0||nx>=W||ny>=H) continue;
            var j=ny*W+nx; if(!D.bnd[j] && !isWaterTile(j)) return true; }
          return false;
        }
        for(var i=0;i<W*H;i++){ var x=i%W,y=(i/W)|0,
          tn=(Lt[D.terr[i]]||'').toUpperCase(),
          h=(Lh[D.hgt[i]]||'').toUpperCase(),
          v=(Lv[D.veg[i]]||'').toUpperCase(), c, isWater=false;
          if(tn==='WATER'||h.indexOf('LAKE')>=0){
            isWater=true;
            c = h.indexOf('LAKE')>=0 ? [40,118,124]            // lake — teal
              : touchesLand(x,y) ? [70,120,168]                // coast
              : [20,42,78];                                    // ocean — deep
          } else {
            c=tcol(tn);   // keep true terrain colour; veg = stripes
          }
          if(D.bnd[i]){var g=lum(c)*0.42;c=[g,g,g];}
          else if(h.indexOf('MOUNTAIN')>=0||h.indexOf('VOLCANO')>=0){
            var b=lum(c)*0.6+26;
            c=h.indexOf('VOLCANO')>=0?[b+14,b-4,b-6]:[b,b,b+3];
          } else if(h.indexOf('HILL')>=0)c=[c[0]-16,c[1]-16,c[2]-10];
          var ce=cen(x,y);
          ctx.fillStyle='rgb('+(c[0]|0)+','+(c[1]|0)+','+(c[2]|0)+')';
          hexp(ce[0],ce[1],S); ctx.fill();
          if(!D.bnd[i]&&!isWater&&h.indexOf('HILL')>=0){ // hill bump
            ctx.fillStyle='rgba(0,0,0,0.34)'; var bs=S*0.3;
            ctx.beginPath();
            ctx.moveTo(ce[0]-bs,ce[1]+bs*0.7);
            ctx.lineTo(ce[0],ce[1]-bs*0.6);
            ctx.lineTo(ce[0]+bs,ce[1]+bs*0.7); ctx.closePath(); ctx.fill(); }
          if(!D.bnd[i]&&!isWater){            // veg = stripes (no recolour)
            var ns = v.indexOf('JUNGLE')>=0 ? 3
              : (v.indexOf('FOREST')>=0||v.indexOf('TREE')>=0) ? 2
              : v.indexOf('SCRUB')>=0 ? 1 : 0;
            if(ns){ ctx.strokeStyle='rgba(20,40,16,0.55)';
              ctx.lineWidth=Math.max(1,S/7); var sw=S*0.62, gap=S*0.32;
              for(var s=0;s<ns;s++){ var sy=ce[1]+(s-(ns-1)/2)*gap;
                ctx.beginPath(); ctx.moveTo(ce[0]-sw/2,sy);
                ctx.lineTo(ce[0]+sw/2,sy); ctx.stroke(); } } }
          if(!D.bnd[i]&&D.cs[i]){ ctx.fillStyle='#ff2daa';
            ctx.beginPath(); ctx.arc(ce[0],ce[1],S*0.4,0,7); ctx.fill(); }
        }
        ctx.strokeStyle='#4696eb'; ctx.lineWidth=Math.max(2,S/4);
        var DXe=[0,1,1,1,0,-1],DXo=[-1,0,1,0,-1,-1],DY=[1,1,0,-1,-1,0],RB={1:5,2:4,4:3};
        for(var i=0;i<W*H;i++){ if(!D.riv[i]||D.bnd[i])continue;
          var x=i%W,y=(i/W)|0,ce=cen(x,y);
          for(var bit in RB){ if(!(D.riv[i]&bit))continue;
            var di=RB[bit],ox=(y%2===0?DXe:DXo)[di],nx=x+ox,ny=y+DY[di];
            if(nx<0||ny<0||nx>=W||ny>=H)continue;
            var nc=cen(nx,ny),mx=(ce[0]+nc[0])/2,my=(ce[1]+nc[1])/2,
              dx=nc[0]-ce[0],dy=nc[1]-ce[1],L=Math.hypot(dx,dy)||1,hh=S/Math.sqrt(3)*0.96;
            ctx.beginPath();
            ctx.moveTo(mx-(-dy/L)*hh,my-(dx/L)*hh);
            ctx.lineTo(mx+(-dy/L)*hh,my+(dx/L)*hh); ctx.stroke(); }
        }
        // resource icons
        var is=S*1.5;
        for(var i=0;i<W*H;i++){ if(D.res[i]<0||D.bnd[i])continue;
          var im=icons[slug(D.L.res[D.res[i]])]; if(!im||!im.complete)continue;
          var x=i%W,y=(i/W)|0,ce=cen(x,y);
          ctx.drawImage(im,ce[0]-is/2,ce[1]-is/2,is,is); }
        (D.caps||[]).forEach(function(p){ var ce=cen(p[0],p[1]),R=S*1.12;
          ctx.fillStyle='#fff'; ctx.strokeStyle='#000'; ctx.lineWidth=2;
          ctx.beginPath(); ctx.arc(ce[0],ce[1],R,0,7); ctx.fill(); ctx.stroke();
          ctx.fillStyle='#ff2daa'; ctx.beginPath();
          for(var k=0;k<10;k++){ var a=Math.PI/180*(-90+k*36),
            rr=(k%2?R*0.36:R*0.82),px=ce[0]+rr*Math.cos(a),py=ce[1]+rr*Math.sin(a);
            k?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); ctx.fill();
        });
        baseImg=ctx.getImageData(0,0,cv.width,cv.height);
      }
      var yieldHi=null;   // {arr:'yf'|'yi'|'ys'|'yw', n:int}
      function overlay(hoverIdx){
        if(baseImg) ctx.putImageData(baseImg,0,0);
        var W=D.w, res=pinRes||activeRes;
        if(res!=null){ ctx.strokeStyle='#ffe24a'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#ffe24a'; ctx.shadowBlur=S;
          for(var i=0;i<D.terr.length;i++){ if(D.res[i]<0)continue;
            if(slug(D.L.res[D.res[i]])!==res)continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.96); ctx.stroke(); }
          ctx.shadowBlur=0;
        }
        if(yieldHi){ var A=D[yieldHi.arr]||[];
          ctx.strokeStyle='#6fe06f'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#6fe06f'; ctx.shadowBlur=S;
          for(var i=0;i<A.length;i++){ if((A[i]||0)<yieldHi.n||D.bnd[i])continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.96); ctx.stroke(); }
          ctx.shadowBlur=0;
        }
        if(hoverIdx>=0){ var ce=cen(hoverIdx%W,(hoverIdx/W)|0);
          ctx.strokeStyle='#fff'; ctx.lineWidth=Math.max(2,S/3);
          hexp(ce[0],ce[1],S*0.98); ctx.stroke(); }
      }
      fetch(base+'data/gen/'+gid+'.json').then(function(r){return r.json();})
      .then(function(d){
        D=d; cv.width=Math.ceil(d.w*HW+HW/2+2*PAD);
        cv.height=Math.ceil((d.h-1)*VS+2*S+2*PAD);
        // counts + preload icons
        var cnt={};
        for(var i=0;i<d.res.length;i++){ if(d.res[i]<0)continue;
          var nm=d.L.res[d.res[i]]; cnt[nm]=(cnt[nm]||0)+1; }
        var names=Object.keys(cnt).sort();
        var pending=names.length;
        function ready(){ pending--; if(pending<=0){ drawBase(); overlay(-1);} }
        if(!names.length) { drawBase(); overlay(-1); }
        names.forEach(function(nm){ var sg=slug(nm), im=new Image();
          icons[sg]=im; im.onload=ready; im.onerror=ready;
          im.src=base+'img/icons/resources/'+sg+'.png'; });
        // panel
        var rp=document.getElementById('respanel');
        names.forEach(function(nm){ var sg=slug(nm),
          el=document.createElement('span'); el.className='rchip';
          el.innerHTML=nm+' <b>'+cnt[nm]+'</b>';
          el.addEventListener('mouseenter',function(){ if(pinRes)return;
            activeRes=sg; overlay(-1); });
          el.addEventListener('mouseleave',function(){ if(pinRes)return;
            activeRes=null; overlay(-1); });
          el.addEventListener('click',function(){
            if(pinRes===sg){ pinRes=null; el.classList.remove('pin'); }
            else { document.querySelectorAll('.rchip.pin').forEach(function(o){o.classList.remove('pin');});
              pinRes=sg; el.classList.add('pin'); }
            activeRes=null; overlay(-1);
          });
          rp.appendChild(el);
        });
      });
      cv.addEventListener('mousemove',function(e){
        if(!D)return; var rect=cv.getBoundingClientRect(),
          mx=(e.clientX-rect.left)*cv.width/rect.width,
          my=(e.clientY-rect.top)*cv.height/rect.height,
          W=D.w,H=D.h,ry=Math.max(0,Math.min(H-1,Math.round((my-PAD-S)/VS))),
          best=-1,bd=S*S*1.5;
        for(var yy=ry-1;yy<=ry+1;yy++){ if(yy<0||yy>=H)continue;
          for(var xx=0;xx<W;xx++){ var ce=cen(xx,yy),
            dd=(ce[0]-mx)*(ce[0]-mx)+(ce[1]-my)*(ce[1]-my);
            if(dd<bd){bd=dd;best=yy*W+xx;} } }
        overlay(best);
        if(best<0){ tip.style.display='none'; return; }
        var i=best,x=i%W,y=(i/W)|0,rn=D.res[i]>=0?D.L.res[D.res[i]]:null,
          isCap=(D.caps||[]).some(function(p){return p[0]===x&&p[1]===y;});
        tip.innerHTML='<b>('+x+','+y+')</b> '+(D.L.terr[D.terr[i]]||'?')
          +'<br>'+(D.L.hgt[D.hgt[i]]||'Flat')+' · '+(D.L.veg[D.veg[i]]||'—')
          +(rn?'<br><b>'+rn+'</b>':'')
          +(isCap?'<br><b style="color:#ff2daa">★ CAPITAL</b>':'')
          +(D.bnd[i]?'<br><i>off-map</i>':'')
          +(D.cs[i]?'<br>city site':'');
        tip.style.display='block';
        tip.style.left=(e.clientX-rect.left+14)+'px';
        tip.style.top=(e.clientY-rect.top+12)+'px';
      });
      cv.addEventListener('mouseleave',function(){
        tip.style.display='none'; overlay(-1); });
      // yield-cell hover → highlight matching tiles
      var YA={food:'yf',iron:'yi',stone:'ys',wood:'yw'};
      document.querySelectorAll('td.yc').forEach(function(td){
        td.addEventListener('mouseenter',function(){
          if(!D) return;
          yieldHi={arr:YA[td.getAttribute('data-y')],
                   n:parseInt(td.getAttribute('data-n'))};
          overlay(-1);
        });
        td.addEventListener('mouseleave',function(){
          yieldHi=null; if(D) overlay(-1);
        });
      });
    })();
  </script>
</Base>
