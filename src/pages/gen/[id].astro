---
import Base from '../../layouts/Base.astro';
import data from '../../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const d = data as any;
  return d.gens.map((g: any) => ({
    params: { id: g.id }, props: { g, resTax: d.resTax } }));
}
const { g, resTax } = Astro.props as { g: any; resTax: any };
---
<Base title={`Gen · ${g.label}`}>
  <p class="back"><a id="backlink" href={baseUrl}>← all maps</a></p>
  <script is:inline define:vars={{ base: baseUrl }}>
    // Default back to the atlas (now the root). Only return to
    // /recommended if that's actually where you came from.
    (function(){
      var a=document.getElementById('backlink');
      try{
        var r=document.referrer;
        if(r && r.indexOf(location.origin)===0
           && r.indexOf(base+'recommended')>=0){
          a.href=base+'recommended'; a.textContent='← all recommended';
        }
      }catch(e){}
    })();
  </script>
  <script is:inline>
    (function(){
      var b=document.getElementById('pscopy'),
          v=document.getElementById('psval');
      if(!b||!v) return;
      b.addEventListener('click',function(){
        navigator.clipboard.writeText(v.textContent.trim()).then(function(){
          var o=b.textContent; b.textContent='✓ copied';
          setTimeout(function(){ b.textContent=o; },1500);
        });
      });
    })();
  </script>
  <p class="lede">
    <b>{g.label}</b> · seed {g.seed}. <span class="mono">{g.setting}</span>.
    <b>Hover a tile</b> for details; <b>scroll to zoom, drag to pan</b>;
    hover a resource or yield cell to light up matching tiles.
    Pink ★ = capital · pink • = city site · blue = river.
    (<a href={`${baseUrl}img/${g.img}`} target="_blank" rel="noopener">static image ↗</a>)
  </p>

  {g.ps && (
    <div class="ps">
      <div class="ps__hd">
        <span class="ps__lbl">Old World Parameter String</span>
        <button id="pscopy" type="button">⧉ copy</button>
      </div>
      <code id="psval" class="ps__v">{g.ps}</code>
      <p class="ps__hint">Paste into Old World → <b>New Game → Parameter
        String</b> to generate this exact map (script · size · aspect ·
        mirror · point-symmetry · options · <b>seed {g.seed}</b>).</p>
    </div>
  )}

  <div id="mapwrap"><canvas id="cv"></canvas><div id="tip"></div>
    <button id="reset" type="button">⤾ reset view</button>
    <div id="zhint">scroll = zoom · drag = pan</div></div>

  <h2 class="sec">Resources <span class="rh">(hover a pill → highlight on map · grey = absent)</span></h2>
  <div id="respanel"></div>

  <h2 class="sec">Stats</h2>
  <div class="stats">
    <div class="col">
      <h3>Capital distance</h3>
      <table class="kv">
        <tr><td>Land-connected</td><td class={g.conn ? 'good' : 'bad'}>
          {g.conn ? 'YES' : 'NO'}</td></tr>
        <tr><td>Crow (hex)</td><td><b>{g.crow ?? '—'}</b></td></tr>
        <tr><td>Land path</td><td><b>{g.land ?? '—'}</b></td></tr>
        <tr><td>Sea path</td><td>{g.water ?? '—'}</td></tr>
        <tr><td>Scout orders</td><td><b>{g.scout ?? '—'}</b></td></tr>
        <tr><td>Slinger L/S/Hatti</td><td>
          {g.slLand ?? '—'}/{g.slSea ?? '—'}/{g.slHatti ?? '—'}</td></tr>
      </table>
    </div>
    <div class="col">
      <h3>Map</h3>
      <table class="kv">
        <tr id="csrow" style="cursor:crosshair"><td>City sites <span class="rh">(hover)</span></td><td><b>{g.sites ?? '—'}</b></td></tr>
        <tr><td>Playable tiles</td><td>{g.tiles ?? '—'}</td></tr>
        <tr><td>Land tiles</td><td>{g.landTiles ?? '—'}</td></tr>
        <tr id="reachrow" style="cursor:crosshair"><td>Cap-reachable land <span class="rh">(hover)</span></td><td><b id="s_reach">—</b></td></tr>
        <tr><td>Freshwater tiles</td><td id="s_fw">—</td></tr>
        <tr><td>River tiles</td><td id="s_riv">—</td></tr>
        <tr><td>Ocean %</td><td>{g.oceanPct ?? '—'}%</td></tr>
        <tr><td>Tribes / Res</td><td>{g.tribes ?? '—'} / {g.res ?? '—'}</td></tr>
      </table>
    </div>
    <div class="col">
      <h3>Tiles by exact yield <span class="rh">(hover → highlight)</span></h3>
      <table class="kv yt"><thead><tr><th>yld</th>
        <th><img class="yi" src={`${baseUrl}img/icons/yields/food.png`} alt="Food"/></th>
        <th><img class="yi" src={`${baseUrl}img/icons/yields/iron.png`} alt="Iron"/></th>
        <th><img class="yi" src={`${baseUrl}img/icons/yields/stone.png`} alt="Stone"/></th>
        <th><img class="yi" src={`${baseUrl}img/icons/yields/wood.png`} alt="Wood"/></th></tr></thead>
        <tbody id="ytbody"><tr><td colspan="5" class="dim">loading…</td></tr></tbody>
      </table>
    </div>
  </div>

  <h2 class="sec">If every tile had its optimal improvement — total map income</h2>
  <p class="expl">Sum of the best Food/Iron/Stone/Wood every playable
    tile could produce with its ideal improvement (Farm, Mine, Quarry,
    Lumbermill, Pasture, Camp, Nets…). Useful for comparing the raw
    economic ceiling of maps.</p>
  <div id="totals" class="totals">—</div>

  <style>
    .back { font-size:0.8rem; margin:0 0 0.4rem; }
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1rem; line-height:1.55; color:var(--text-soft);
      max-width:92ch; margin:0.2rem 0 1rem; }
    #mapwrap { position:relative; width:100%; height:72vh; overflow:hidden;
      border-radius:5px; border:1px solid var(--border-strong);
      background:#0b0c0f; cursor:grab; touch-action:none; }
    #mapwrap.drag { cursor:grabbing; }
    #cv { position:absolute; top:0; left:0; transform-origin:0 0;
      display:block; image-rendering:auto; }
    #tip { position:absolute; pointer-events:none; display:none; z-index:9;
      background:rgba(12,13,16,0.96); border:1px solid var(--gold-deep);
      border-radius:5px; padding:0.4rem 0.55rem; font-size:0.74rem;
      color:var(--text); font-family:var(--font-ui); white-space:nowrap;
      line-height:1.45; }
    #tip b { color:var(--gold); }
    #tip .ti { width:15px; height:15px; vertical-align:-3px; }
    :global(.yi) { width:18px; height:18px; vertical-align:-4px; display:inline-block; }
    :global(.yt th .yi) { width:15px; height:15px; vertical-align:-1px; }
    #reset { position:absolute; left:8px; bottom:8px; z-index:8;
      background:rgba(12,13,16,0.85); color:var(--text-soft);
      border:1px solid var(--border-strong); border-radius:5px;
      padding:0.25rem 0.6rem; font-size:0.72rem; cursor:pointer; }
    #reset:hover { color:var(--gold); border-color:var(--gold-deep); }
    #zhint { position:absolute; right:8px; bottom:6px; font-size:0.64rem;
      color:var(--text-faint); background:rgba(12,13,16,0.65);
      padding:0.1rem 0.45rem; border-radius:4px; pointer-events:none; }
    .sec { font-size:1.12rem; color:var(--gold); border-bottom:1px solid
      var(--gold-deep); padding-bottom:0.25rem; margin:1.5rem 0 0.55rem; }
    .rh { font-size:0.72rem; color:var(--text-faint); font-weight:400; }
    .expl { font-size:0.82rem; color:var(--text-soft); line-height:1.5;
      max-width:88ch; margin:0 0 0.6rem; }
    /* :global — these nodes are built in JS (buildPanel), so Astro's
       scoped data-attr is absent and a plain scoped rule won't match. */
    :global(#respanel .rg) { margin:0.25rem 0 0.55rem; }
    :global(#respanel .rg__t) { font-size:0.64rem; letter-spacing:0.12em;
      text-transform:uppercase; color:var(--text-dim); margin-bottom:0.25rem; }
    :global(#respanel .row) { display:flex; flex-wrap:wrap; gap:0.3rem; }
    :global(#respanel .rchip) { display:inline-flex; align-items:center;
      gap:0.25rem; background:var(--bg-elev);
      border:1px solid var(--gold-deep);
      border-radius:999px; padding:0.06rem 0.5rem 0.06rem 0.28rem;
      font-size:0.73rem; color:var(--text); line-height:1.4; }
    :global(#respanel .rchip img) { width:14px; height:14px; display:block; }
    :global(#respanel .rchip b) { color:var(--gold); }
    :global(#respanel .rchip.has) { cursor:pointer; }
    :global(#respanel .rchip.has:hover),
    :global(#respanel .rchip.pin) { border-color:var(--gold);
      background:#231f0d; color:var(--gold); }
    :global(#respanel .rchip.off) { background:transparent;
      border-color:var(--border); color:var(--text-dim); opacity:0.5; }
    .stats { display:grid; gap:1.4rem;
      grid-template-columns:repeat(3,minmax(0,1fr)); }
    @media (max-width:820px){ .stats{ grid-template-columns:1fr 1fr; } }
    @media (max-width:560px){ .stats{ grid-template-columns:1fr; } }
    .col { min-width:0; }
    .stats h3 { font-size:0.96rem; color:var(--text); margin:0 0 0.25rem; }
    .kv { width:100%; border-collapse:collapse; font-size:0.85rem; }
    .kv td { padding:0.24rem 0.4rem; border-bottom:1px solid var(--border); }
    .kv td:first-child { color:var(--text-soft); }
    .kv td:last-child { text-align:right; }
    .kv b { color:var(--text); }
    /* :global — tbody rows are built in JS, scoped rules wouldn't match */
    :global(.yt) { width:100%; table-layout:fixed; }
    :global(.yt th), :global(.yt td) { padding:0.18rem 0.55rem; }
    /* numeric body cells right-aligned */
    :global(.yt td) { text-align:right; font-family:var(--font-mono);
      font-size:0.82em; }
    /* yield-icon headers centred over their column */
    :global(.yt th) { font-size:0.6rem; color:var(--text-dim);
      text-transform:uppercase; text-align:center;
      border-bottom:1px solid var(--border-strong); }
    /* first column = bucket label, left-aligned */
    :global(.yt th:first-child), :global(.yt td:first-child) {
      text-align:left; width:3rem; color:var(--text-dim);
      font-family:var(--font-ui); }
    :global(.yt td.yc) { cursor:crosshair; }
    :global(.yt td.yc:hover) { background:#16290f; color:#9fd07f; }
    .mono { font-family:var(--font-mono); font-size:0.86em; }
    .ps { background:var(--bg-elev); border:1px solid var(--gold-deep);
      border-radius:8px; padding:0.6rem 0.9rem; margin:0 0 1rem;
      max-width:80ch; }
    .ps__hd { display:flex; align-items:center; gap:0.8rem;
      margin-bottom:0.4rem; }
    .ps__lbl { font-size:0.62rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--gold-soft); font-weight:700; }
    #pscopy { margin-left:auto; font-family:var(--font-ui);
      font-size:0.74rem; font-weight:700; color:var(--gold);
      background:#231f0d; border:1px solid var(--gold-deep);
      border-radius:5px; padding:0.22rem 0.6rem; cursor:pointer; }
    #pscopy:hover { background:#2e2810; border-color:var(--gold-soft); }
    .ps__v { display:block; font-family:var(--font-mono);
      font-size:0.78rem; color:var(--text); background:#0b0c0f;
      border:1px solid var(--border-strong); border-radius:5px;
      padding:0.5rem 0.6rem; word-break:break-all; line-height:1.5;
      user-select:all; }
    .ps__hint { font-size:0.74rem; color:var(--text-faint);
      margin:0.45rem 0 0; line-height:1.45; }
    .ps__hint b { color:var(--text-soft); }
    .dim { color:var(--text-dim); }
    .good { color:#9fd07f; font-weight:700; }
    .bad { color:#d08070; font-weight:700; }
    /* :global — #totals is filled via innerHTML (JS) */
    :global(.totals) { display:flex; flex-wrap:wrap; gap:1.6rem;
      font-size:1.05rem; align-items:center; }
    :global(.totals span) { display:inline-flex; align-items:center;
      gap:0.45rem; color:var(--text-soft); }
    :global(.totals b) { color:var(--gold); font-size:1.25rem;
      font-variant-numeric:tabular-nums; }
  </style>

  <script is:inline define:vars={{ gid: g.id, base: baseUrl, resTax }}>
    (function(){
      var TERR={WATER:[38,71,110],TEMPERATE:[104,138,74],LUSH:[74,110,56],
        ARID:[170,148,95],SAND:[206,184,120],MARSH:[96,110,80],
        TUNDRA:[200,205,210],URBAN:[150,128,116]};
      var ALIAS={marble:'stone',ore:'iron'};
      function tcol(n){ return TERR[n.toUpperCase().replace(/ /g,'_')]||[90,90,90]; }
      function lum(c){ return 0.299*c[0]+0.587*c[1]+0.114*c[2]; }
      function slug(nm){ var s=nm.toLowerCase().replace(/ /g,'_'); return ALIAS[s]||s; }
      var wrap=document.getElementById('mapwrap'), cv=document.getElementById('cv'),
          tip=document.getElementById('tip'), ctx=cv.getContext('2d'),
          S=11, HW=Math.sqrt(3)*S, VS=1.5*S, PAD=4, D=null, baseImg=null,
          icons={}, activeRes=null, pinRes=null, yieldHi=null, csHi=false, unHi=false,
          capHi=false, k=1, tx=0, ty=0;
      // OW origin is bottom-left (y grows north). Flip data-row → screen-Y
      // so row 0 paints at the bottom. Horizontal stagger stays keyed to the
      // true data-y parity so the odd-r tiling (and rivers/caps via cen) stay
      // coherent — this is a pure vertical reflection of the raster.
      function cen(x,y){ return [x*HW+(y%2===0?HW/2:0)+HW/2+PAD, ((D?D.h:0)-1-y)*VS+S+PAD]; }
      function hexp(cx,cy,r){ ctx.beginPath();
        for(var i=0;i<6;i++){ var a=Math.PI/180*(60*i-90),
          px=cx+r*Math.cos(a),py=cy+r*Math.sin(a);
          i?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); }
      // contain scale: whole map fits in the viewport (both axes)
      function minK(){ return (cv.width && cv.height)
        ? Math.min(wrap.clientWidth/cv.width, wrap.clientHeight/cv.height)
        : 0.15; }
      function clampView(){
        var W=wrap.clientWidth, H=wrap.clientHeight,
            kw=cv.width*k, kh=cv.height*k;
        tx = kw<=W ? (W-kw)/2 : Math.min(0, Math.max(W-kw, tx));
        ty = kh<=H ? (H-kh)/2 : Math.min(0, Math.max(H-kh, ty));
      }
      function applyView(){ clampView();
        cv.style.transform='translate('+tx+'px,'+ty+'px) scale('+k+')'; }
      var DXe=[0,1,1,1,0,-1],DXo=[-1,0,1,0,-1,-1],DY=[1,1,0,-1,-1,0];
      function drawBase(){
        var W=D.w,H=D.h,Lt=D.L.terr,Lh=D.L.hgt,Lv=D.L.veg;
        ctx.fillStyle='#0b0c0f'; ctx.fillRect(0,0,cv.width,cv.height);
        function isW(j){ return (Lt[D.terr[j]]||'').toUpperCase()==='WATER'; }
        function coastal(x,y){ for(var q=0;q<6;q++){
          var nx=x+(y%2===0?DXe:DXo)[q],ny=y+DY[q];
          if(nx<0||ny<0||nx>=W||ny>=H)continue;
          var j=ny*W+nx; if(!D.bnd[j]&&!isW(j))return true;} return false; }
        for(var i=0;i<W*H;i++){ var x=i%W,y=(i/W)|0,
          tn=(Lt[D.terr[i]]||'').toUpperCase(),
          h=(Lh[D.hgt[i]]||'').toUpperCase(),
          vg=(Lv[D.veg[i]]||'').toUpperCase(), c, water=false;
          if(tn==='WATER'||h.indexOf('LAKE')>=0){ water=true;
            c=h.indexOf('LAKE')>=0?[40,118,124]:coastal(x,y)?[70,120,168]:[20,42,78];
          } else c=tcol(tn).slice();
          if(D.bnd[i]){var gg=lum(c)*0.42;c=[gg,gg,gg];}
          else if(h.indexOf('MOUNTAIN')>=0||h.indexOf('VOLCANO')>=0){
            var b=lum(c)*0.6+26; c=h.indexOf('VOLCANO')>=0?[b+14,b-4,b-6]:[b,b,b+3]; }
          var ce=cen(x,y);
          ctx.fillStyle='rgb('+(c[0]|0)+','+(c[1]|0)+','+(c[2]|0)+')';
          hexp(ce[0],ce[1],S); ctx.fill();
          if(D.bnd[i]||water) continue;
          // HILL channel: tile-wide shaded relief (independent of veg)
          if(h.indexOf('HILL')>=0){
            ctx.save(); hexp(ce[0],ce[1],S); ctx.clip();
            ctx.fillStyle='rgba(255,255,255,0.16)';
            ctx.fillRect(ce[0]-S,ce[1]-S,2*S,S*0.85);
            ctx.fillStyle='rgba(0,0,0,0.30)';
            ctx.fillRect(ce[0]-S,ce[1]+S*0.05,2*S,S);
            ctx.restore();
          }
          // VEG channel: glyphs on top (compose with hill)
          var jg=vg.indexOf('JUNGLE')>=0,
              fr=vg.indexOf('FOREST')>=0||vg.indexOf('TREE')>=0,
              sc=vg.indexOf('SCRUB')>=0||vg.indexOf('BRUSH')>=0;
          var onHill=h.indexOf('HILL')>=0;
          if(jg||fr){ var nt=jg?3:2, tw=S*0.26, th=S*0.62,
              gc=jg?'rgba(14,50,16,0.95)':'rgba(24,68,26,0.95)',
              // sit trees up near the hill crest if on a hill
              yb=ce[1]+(onHill?-S*0.12:S*0.24);
            for(var tk=0;tk<nt;tk++){ var tx2=ce[0]+(tk-(nt-1)/2)*(tw*1.25);
              ctx.fillStyle='rgba(60,40,20,0.9)';
              ctx.fillRect(tx2-tw*0.16,yb-th*0.18,tw*0.32,th*0.34);
              ctx.fillStyle=gc; ctx.beginPath();
              ctx.moveTo(tx2,yb-th); ctx.lineTo(tx2-tw,yb);
              ctx.lineTo(tx2+tw,yb); ctx.closePath(); ctx.fill(); } }
          else if(sc){ // tall grass — fanned blades, atop hill if hill
            ctx.strokeStyle='rgba(150,158,86,0.92)';
            ctx.lineWidth=Math.max(1,S/9); ctx.lineCap='round';
            var gb=ce[1]+(onHill?S*0.04:S*0.34), gh=S*0.5;
            for(var bk=-2;bk<=2;bk++){ var bx=ce[0]+bk*S*0.16;
              ctx.beginPath(); ctx.moveTo(bx,gb);
              ctx.lineTo(bx+bk*S*0.06,gb-gh*(0.7+Math.abs(bk)*0.06));
              ctx.stroke(); } ctx.lineCap='butt'; }
          if(vg.indexOf('MARSH')>=0||tn==='MARSH'){ // marsh — reeds+water
            ctx.fillStyle='rgba(40,90,96,0.55)';
            ctx.beginPath(); ctx.ellipse(ce[0],ce[1]+S*0.34,S*0.5,S*0.2,0,0,7); ctx.fill();
            ctx.strokeStyle='rgba(70,120,90,0.95)';
            ctx.lineWidth=Math.max(1,S/9); ctx.lineCap='round';
            for(var rk=-1;rk<=1;rk++){ var rx=ce[0]+rk*S*0.24;
              ctx.beginPath(); ctx.moveTo(rx,ce[1]+S*0.36);
              ctx.lineTo(rx,ce[1]-S*0.18); ctx.stroke(); }
            ctx.lineCap='butt'; }
          if(D.res[i]>=0){ var im=icons[slug(D.L.res[D.res[i]])];
            if(im&&im.complete&&im.naturalWidth){ var iz=S*1.5;
              ctx.drawImage(im,ce[0]-iz/2,ce[1]-iz/2,iz,iz); } }
          if(D.cs[i]){ ctx.fillStyle='#ff2daa';
            ctx.beginPath(); ctx.arc(ce[0],ce[1],S*0.34,0,7); ctx.fill(); }
        }
        // rivers
        ctx.strokeStyle='#4696eb'; ctx.lineWidth=Math.max(2,S/4);
        var RB={1:5,2:4,4:3};
        for(var i=0;i<W*H;i++){ if(!D.riv[i]||D.bnd[i])continue;
          var x=i%W,y=(i/W)|0,ce=cen(x,y);
          for(var bit in RB){ if(!(D.riv[i]&bit))continue;
            var di=RB[bit],ox=(y%2===0?DXe:DXo)[di],nx=x+ox,ny=y+DY[di];
            if(nx<0||ny<0||nx>=W||ny>=H)continue;
            var nc=cen(nx,ny),mx=(ce[0]+nc[0])/2,my=(ce[1]+nc[1])/2,
              dx=nc[0]-ce[0],dy=nc[1]-ce[1],L=Math.hypot(dx,dy)||1,hh=S/Math.sqrt(3)*0.96;
            ctx.beginPath(); ctx.moveTo(mx-(-dy/L)*hh,my-(dx/L)*hh);
            ctx.lineTo(mx+(-dy/L)*hh,my+(dx/L)*hh); ctx.stroke(); } }
        (D.caps||[]).forEach(function(p){ var ce=cen(p[0],p[1]),R=S*1.1;
          ctx.fillStyle='#fff'; ctx.strokeStyle='#000'; ctx.lineWidth=2;
          ctx.beginPath(); ctx.arc(ce[0],ce[1],R,0,7); ctx.fill(); ctx.stroke();
          ctx.fillStyle='#ff2daa'; ctx.beginPath();
          for(var q=0;q<10;q++){ var a=Math.PI/180*(-90+q*36),
            rr=(q%2?R*0.36:R*0.82),px=ce[0]+rr*Math.cos(a),py=ce[1]+rr*Math.sin(a);
            q?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); ctx.fill(); });
        baseImg=ctx.getImageData(0,0,cv.width,cv.height);
      }
      function overlay(hi){
        if(baseImg) ctx.putImageData(baseImg,0,0);
        var W=D.w, res=pinRes||activeRes;
        if(res){ ctx.strokeStyle='#ffe24a'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#ffe24a'; ctx.shadowBlur=S;
          for(var i=0;i<D.res.length;i++){ if(D.res[i]<0)continue;
            if(slug(D.L.res[D.res[i]])!==res)continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.95); ctx.stroke(); }
          ctx.shadowBlur=0; }
        if(yieldHi){ var A=D[yieldHi.arr]||[],lo=yieldHi.lo,hh=yieldHi.hi;
          ctx.strokeStyle='#6fe06f'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#6fe06f'; ctx.shadowBlur=S;
          for(var i=0;i<A.length;i++){ var v=A[i]||0;
            if(D.bnd[i]||v<lo||(hh!=null&&v>=hh))continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.95); ctx.stroke(); }
          ctx.shadowBlur=0; }
        if(unHi && D.un){
          ctx.strokeStyle='#ff5c3a'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#ff5c3a'; ctx.shadowBlur=S;
          for(var i=0;i<D.un.length;i++){ if(!D.un[i])continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.95); ctx.stroke(); }
          ctx.shadowBlur=0; }
        if(csHi || (hi>=0 && D.cs[hi])){
          ctx.strokeStyle='#ff2daa'; ctx.lineWidth=Math.max(2,S/3);
          ctx.shadowColor='#ff2daa'; ctx.shadowBlur=S;
          for(var i=0;i<D.cs.length;i++){ if(!D.cs[i]||D.bnd[i])continue;
            var ce=cen(i%W,(i/W)|0); hexp(ce[0],ce[1],S*0.95); ctx.stroke(); }
          ctx.shadowBlur=0; }
        if(capHi){
          var lp=(D.capPath&&D.capPath.length>1)?D.capPath:null,
              wp=(!lp&&D.capPathW&&D.capPathW.length>1)?D.capPathW:null,
              pp=lp||wp;
          if(pp){ ctx.strokeStyle=lp?'#35e0e0':'#ff3b30';
            ctx.lineWidth=Math.max(3,S/2);
            ctx.lineJoin='round'; ctx.lineCap='round';
            ctx.shadowColor=ctx.strokeStyle; ctx.shadowBlur=S*1.2;
            ctx.beginPath();
            pp.forEach(function(p,j){ var c=cen(p[0],p[1]);
              j?ctx.lineTo(c[0],c[1]):ctx.moveTo(c[0],c[1]); });
            ctx.stroke(); ctx.shadowBlur=0; } }
        if(hi>=0){ var ce=cen(hi%W,(hi/W)|0);
          ctx.strokeStyle='#fff'; ctx.lineWidth=Math.max(2,S/3);
          hexp(ce[0],ce[1],S*0.98); ctx.stroke(); }
      }
      function buildYields(){
        var tb=document.getElementById('ytbody'); tb.innerHTML='';
        var KS=[['food','yf'],['iron','yi'],['stone','ys'],['wood','yw']];
        for(var bi=0;bi<8;bi++){ var n=5+bi,
          tr=document.createElement('tr'),
          td0=document.createElement('td'); td0.textContent=(n>=12?'12+':n);
          tr.appendChild(td0);
          KS.forEach(function(p){ var td=document.createElement('td');
            td.className='yc'; td.textContent=(D.buck[p[0]]||[])[bi]||0;
            var lo=n*10, hi=(n>=12?null:(n+1)*10);
            td.addEventListener('mouseenter',function(){ yieldHi={arr:p[1],lo:lo,hi:hi}; overlay(-1); });
            td.addEventListener('mouseleave',function(){ yieldHi=null; overlay(-1); });
            tr.appendChild(td); });
          tb.appendChild(tr); }
      }
      function buildPanel(){
        var rp=document.getElementById('respanel'), cnt=D.rescnt||{};
        function norm(s){ return s.toLowerCase().replace(/[ _]/g,''); }
        var cmap={}; Object.keys(cnt).forEach(function(nm){ cmap[norm(nm)]=cnt[nm]; });
        resTax.forEach(function(grp){ var title=grp[0], list=grp[1],
          g=document.createElement('div'); g.className='rg';
          var t=document.createElement('div'); t.className='rg__t';
          t.textContent=title; g.appendChild(t);
          var row=document.createElement('div'); row.className='row';
          list.forEach(function(nm){ var c=cmap[norm(nm)]||0, sg=slug(nm),
            el=document.createElement('span');
            el.className='rchip '+(c?'has':'off');
            el.innerHTML='<img src="'+base+'img/icons/resources/'+sg
              +'.png" alt=""> '+nm.replace(/_/g,' ')+(c?' <b>'+c+'</b>':'');
            if(c){ el.addEventListener('mouseenter',function(){ if(!pinRes){activeRes=sg;overlay(-1);} });
              el.addEventListener('mouseleave',function(){ if(!pinRes){activeRes=null;overlay(-1);} });
              el.addEventListener('click',function(){
                if(pinRes===sg){pinRes=null;el.classList.remove('pin');}
                else{document.querySelectorAll('.rchip.pin').forEach(function(o){o.classList.remove('pin');});
                  pinRes=sg;el.classList.add('pin');} activeRes=null;overlay(-1); }); }
            row.appendChild(el); });
          g.appendChild(row); rp.appendChild(g); });
      }
      fetch(base+'data/gen/'+gid+'.json').then(function(r){return r.json();})
      .then(function(d){
        D=d; cv.width=Math.ceil(d.w*HW+HW/2+2*PAD);
        cv.height=Math.ceil((d.h-1)*VS+2*S+2*PAD);
        document.getElementById('s_fw').textContent=d.fwTiles!=null?d.fwTiles:'—';
        document.getElementById('s_riv').textContent=d.rivTiles!=null?d.rivTiles:'—';
        var sr=document.getElementById('s_reach');
        if(sr&&d.reachPct!=null){ sr.innerHTML=d.reachPct+'%'
          +(d.split?' <span style="color:#ff5c3a">⚠ SPLIT</span>':''); }
        var T=d.totals||{};
        function yi(n){ return '<img class="yi" src="'+base+'img/icons/yields/'+n+'.png" alt="'+n+'">'; }
        document.getElementById('totals').innerHTML=
          '<span>'+yi('food')+'<b>'+(T.food||0)+'</b></span>'
         +'<span>'+yi('iron')+'<b>'+(T.iron||0)+'</b></span>'
         +'<span>'+yi('stone')+'<b>'+(T.stone||0)+'</b></span>'
         +'<span>'+yi('wood')+'<b>'+(T.wood||0)+'</b></span>';
        buildYields(); buildPanel();
        // preload icons; redraw once loaded so they appear on the map
        var pend=0;
        Object.keys(d.rescnt||{}).forEach(function(nm){ var sg=slug(nm);
          if(icons[sg])return; var im=new Image(); icons[sg]=im; pend++;
          im.onload=function(){ if(--pend<=0){ drawBase(); overlay(-1); } };
          im.onerror=function(){ if(--pend<=0){ drawBase(); overlay(-1); } };
          im.src=base+'img/icons/resources/'+sg+'.png'; });
        drawBase();
        fitView();
      });
      function fitView(){
        // show the entire map by default: scale to contain, then
        // clampView() centres it on whichever axis has slack
        k = minK(); tx = 0; ty = 0; applyView();
      }
      (function(rb){
        rb.addEventListener('mousedown',function(e){ e.stopPropagation(); });
        rb.addEventListener('click',function(e){
          e.stopPropagation(); if(D) fitView(); });
      })(document.getElementById('reset'));
      (function(cr){ if(!cr)return;
        cr.addEventListener('mouseenter',function(){ if(D){csHi=true;overlay(-1);} });
        cr.addEventListener('mouseleave',function(){ csHi=false; if(D)overlay(-1); });
      })(document.getElementById('csrow'));
      (function(rr){ if(!rr)return;
        rr.addEventListener('mouseenter',function(){ if(D){unHi=true;overlay(-1);} });
        rr.addEventListener('mouseleave',function(){ unHi=false; if(D)overlay(-1); });
      })(document.getElementById('reachrow'));
      // zoom
      wrap.addEventListener('wheel',function(e){ if(!D)return; e.preventDefault();
        var r=wrap.getBoundingClientRect(), mx=e.clientX-r.left, my=e.clientY-r.top,
          f=e.deltaY<0?1.15:1/1.15, nk=Math.min(8,Math.max(minK(),k*f));
        tx = mx-(mx-tx)*(nk/k); ty = my-(my-ty)*(nk/k); k=nk; applyView();
      },{passive:false});
      // drag
      var dragging=false, lx=0, ly=0;
      wrap.addEventListener('mousedown',function(e){ dragging=true; lx=e.clientX;
        ly=e.clientY; wrap.classList.add('drag'); tip.style.display='none'; });
      window.addEventListener('mouseup',function(){ dragging=false;
        wrap.classList.remove('drag'); });
      wrap.addEventListener('mousemove',function(e){
        if(dragging){ tx+=e.clientX-lx; ty+=e.clientY-ly; lx=e.clientX;
          ly=e.clientY; applyView(); return; }
        if(!D)return;
        var r=wrap.getBoundingClientRect(),
          px=(e.clientX-r.left-tx)/k, py=(e.clientY-r.top-ty)/k,
          W=D.w,H=D.h, ry=Math.max(0,Math.min(H-1,Math.round((H-1)-(py-PAD-S)/VS))),
          best=-1,bd=S*S*1.6;
        for(var yy=ry-1;yy<=ry+1;yy++){ if(yy<0||yy>=H)continue;
          for(var xx=0;xx<W;xx++){ var ce=cen(xx,yy),
            dd=(ce[0]-px)*(ce[0]-px)+(ce[1]-py)*(ce[1]-py);
            if(dd<bd){bd=dd;best=yy*W+xx;} } }
        var bx=best>=0?best%W:-1, byy=best>=0?(best/W|0):-1;
        capHi=best>=0&&(D.caps||[]).some(function(p){return p[0]===bx&&p[1]===byy;});
        if(!pinRes){ activeRes=(best>=0&&D.res[best]>=0)
            ? slug(D.L.res[D.res[best]]) : null; }
        overlay(best);
        if(best<0){ tip.style.display='none'; return; }
        var i=best,x=i%W,y=(i/W)|0,rn=D.res[i]>=0?D.L.res[D.res[i]]:null,
          isCap=(D.caps||[]).some(function(p){return p[0]===x&&p[1]===y;}),
          f=(D.yf||[])[i]||0,ir=(D.yi||[])[i]||0,st=(D.ys||[])[i]||0,wd=(D.yw||[])[i]||0,
          yl=(f+ir+st+wd>0)?('<br>best F·I·S·W <b>'+(f/10)+'·'+(ir/10)+'·'+(st/10)+'·'+(wd/10)+'</b>'):'',
          riv=((D.rv||[])[i]===1)||(D.riv[i]||0)>0, fw=(D.fw||[])[i]===1,
          rimg=rn?('<img class="ti" src="'+base+'img/icons/resources/'+slug(rn)+'.png" alt=""> '):'',
          extra=[]; if(riv)extra.push('river'); if(fw)extra.push('freshwater');
        tip.innerHTML='<b>('+x+','+y+')</b> '+(D.L.terr[D.terr[i]]||'?')
          +'<br>'+(D.L.hgt[D.hgt[i]]||'Flat')+' · '+(D.L.veg[D.veg[i]]||'no veg')
          +(rn?'<br>'+rimg+'<b>'+rn+'</b>':'')+yl
          +(extra.length?'<br><b>'+extra.join(' · ')+'</b>':'')
          +(isCap?'<br><b style="color:#ff2daa">★ CAPITAL</b>'+(
             (D.capPath&&D.capPath.length>1)
               ? ' <span style="color:#35e0e0">· land path '+(D.capPath.length-1)+' hex</span>'
               : (D.capPathW&&D.capPathW.length>1)
                 ? ' <span style="color:#ff3b30">· no land path · water path '+(D.capPathW.length-1)+' hex</span>'
                 : ' <span style="color:#ff5c3a">· no path</span>'):'')
          +(D.cs[i]?'<br>city site':'')+(D.bnd[i]?'<br><i>off-map</i>':'');
        tip.style.display='block';
        tip.style.left=(e.clientX-r.left+14)+'px';
        tip.style.top=(e.clientY-r.top+12)+'px';
      });
      wrap.addEventListener('mouseleave',function(){
        tip.style.display='none'; capHi=false;
        if(!pinRes)activeRes=null; if(D)overlay(-1); });
    })();
  </script>
</Base>
