      color:var(--text-dim); margin-top:3px; }
  </style>

  <script is:inline>
    (function(){
      var links=[].slice.call(document.querySelectorAll('.snav__l'));
      var secs=links.map(function(l){
        return document.getElementById('cfg-'+l.getAttribute('data-slug')); });
      function spy(){
        var best=0, bt=-1e9;
        secs.forEach(function(s,i){
          if(!s) return;
          var t=s.getBoundingClientRect().top-110;
          if(t<=0 && t>bt){ bt=t; best=i; }
        });
        links.forEach(function(l,i){ l.classList.toggle('on', i===best); });
      }
      window.addEventListener('scroll',function(){
        window.requestAnimationFrame(spy); },{passive:true});
      spy();
    })();
  </script>
</Base>
