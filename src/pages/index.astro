      gap:2px; width:100%; align-items:center; }
    .dot { width:11px; height:11px; border-radius:2px; display:block;
      background:var(--zb); border:1px solid var(--zc); }
    .dot:hover { outline:1px solid var(--gold); outline-offset:1px;
      filter:brightness(1.3); }
    .cd__x { font-size:0.52rem; font-family:var(--font-mono);
      color:var(--text-dim); margin-top:3px; white-space:nowrap; }
  </style>

  <script is:inline>
    (function(){
      var links=[].slice.call(document.querySelectorAll('.snav__l'));
      var secs=links.map(function(l){
        return document.getElementById('cfg-'+l.getAttribute('data-slug')); });
      function spy(){
        var best=0, bt=-1e9;
        secs.forEach(function(s,i){
          if(!s) return;
          var t=s.getBoundingClientRect().top-110;
          if(t<=0 && t>bt){ bt=t; best=i; }
        });
        links.forEach(function(l,i){ l.classList.toggle('on', i===best); });
      }
      window.addEventListener('scroll',function(){
        window.requestAnimationFrame(spy); },{passive:true});
      spy();
    })();
    (function(){
      var btn=document.getElementById('randPick');
      var hint=document.getElementById('randHint');
      if(!btn) return;
      var cfgs=[].slice.call(document.querySelectorAll('.cfg'));
      btn.addEventListener('click',function(){
        if(!cfgs.length) return;
        var el=cfgs[Math.floor(Math.random()*cfgs.length)];
        var nm=el.querySelector('.cfg__name');
        if(hint&&nm) hint.textContent='→ '+nm.textContent;
        el.scrollIntoView({behavior:'smooth',block:'start'});
        cfgs.forEach(function(c){ c.classList.remove('flash'); });
        void el.offsetWidth;            // restart the flash animation
        el.classList.add('flash');
      });
    })();
  </script>
