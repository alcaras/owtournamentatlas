---
import Base from '../layouts/Base.astro';
import dist from '../data/atlas-dist.json';
import gensData from '../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

// The voted tournament pool: one config per map family, the highest-rated
// sibling of each script (see configs.py / vote tally). Order = ballot
// rank, best first; the score itself is intentionally not surfaced here.
const POOL: string[] = [
  'arid-plateau-small-seas-smallest-square-sym',
  'coastal-rain-basin-smallest-wide-nosym',
  'dota-jungle-smallest-square-sym',
  'inland-sea-smallest-square-sym',
  'dota-sand-smallest-square-sym',
  'continent-smallest-wide-sym',
  'dota-water-smallest-square-sym',
  'hardwood-forest-smallest-wide-nosym',
  'archipelago-land-lg-water-sm-smallest-wide-nosym',
  'continent-tiny-square-sym',
  'desert-lush-std-smallest-wide-sym',
  'donut-irreg-low-smallest-square-sym',
  'mountain-pass-tiny-square-sym',
];
const RANK: Record<string, number> = Object.fromEntries(
  POOL.map((s, i) => [s, i]));

const genMap: Record<string, any> = {};
for (const gn of (gensData as any).gens)
  genMap[gn.id] = { sites: gn.sites, land: gn.land, conn: gn.conn,
    reach: gn.reachPct, split: gn.split };
const idFromImg = (slug: string, p: string) => {
  const m = p.match(/seed-(\d+)/); return `${slug}-s${m ? m[1] : 1}`;
};

const pool = dist.configs
  .filter((c: any) => c.slug in RANK)
  .sort((a: any, b: any) => RANK[a.slug] - RANK[b.slug]);

const N = pool[0]?.n ?? 0;

// ---- In-game SETUP GUIDE ---------------------------------------------
// The exact New Game → Advanced Options to set so the in-game generator
// reproduces this config. Universal four (Size/Aspect/Point-Sym/Mirror)
// are parsed from c.setting; the script + its map-options come from
// owmapgen-lab/scripts/configs.py (single source of truth).
const SCRIPT_NAME: Record<string, string> = {
  'Continent': 'Continent',
  'Coastal Rain Basin': 'Coastal Rain Basin',
  'Donut': 'Donut',
  'Archipelago': 'Archipelago',
  'Arid Plateau': 'Arid Plateau',
  'DOTA': 'Duel of the Ancients',
  'Hardwood Forest': 'Hardwood Forest',
  'Inland Sea': 'Inland Sea',
  'Desert': 'Lush Desert',
  'Mountain Pass': 'Mountain Pass',
};
// keyed by `${group}|${variant}` — script-specific dropdowns to change
const SCRIPT_OPTS: Record<string, [string, string][]> = {
  'Arid Plateau|Small Seas': [['Arid Water Size', 'Small']],
  'Coastal Rain Basin|': [],
  'DOTA|Jungle': [['Separating Terrain', 'Jungle']],
  'DOTA|Sand': [['Separating Terrain', 'Sand']],
  'DOTA|Water': [['Separating Terrain', 'Water']],
  'Inland Sea|': [],
  'Continent|': [['Continent Terrain', 'None']],
  'Hardwood Forest|': [],
  'Archipelago|Land Lg · Water Sm': [
    ['Archipelago Landmass', 'Large'],
    ['Archipelago Water Size', 'Merged']],
  'Desert|Lush · Std': [['Desert Coast', 'Lush'], ['Desert Size', 'Standard']],
  'Donut|Irreg Low': [['Donut Irregularity', 'Low']],
  'Mountain Pass|': [],
};
type Row = { label: string; value: string; toggle?: boolean };
function setup(c: any): Row[] {
  const p = (c.setting || '').split(' · ');           // Duel · square · point-sym on · mirror
  const aspect = (p[1] || 'square');
  const sym = (p[2] || '').includes('on');
  const rows: Row[] = [
    { label: 'Map Script', value: SCRIPT_NAME[c.group] || c.group },
    { label: 'Map Size', value: p[0] === 'Tiny' ? 'Tiny' : 'Duel' },
    { label: 'Map Aspect Ratio',
      value: aspect.charAt(0).toUpperCase() + aspect.slice(1) },
  ];
  for (const [l, v] of (SCRIPT_OPTS[`${c.group}|${c.variant || ''}`] || []))
    rows.push({ label: l, value: v });
  rows.push({ label: 'Point Symmetry', value: sym ? 'ON' : 'OFF', toggle: true });
  rows.push({ label: 'Mirror Map', value: 'ON', toggle: true });
  return rows;
}
---
<Base title="Tournament Pool">
  <p class="lede">The {pool.length} maps for the tournament.</p>

  <nav class="snav" id="snav">
    <div class="snav__t">Tournament maps</div>
    {pool.map((c: any) => (
      <a class="snav__l" data-slug={c.slug} href={`#cfg-${c.slug}`}
         title={c.label}>{c.group}{c.variant ? ` · ${c.variant}` : ''}</a>
    ))}
  </nav>

  <div class="pool">
    {pool.map((c: any) => (
      <div class="cfg" id={`cfg-${c.slug}`}>
        <details class="setup">
          <summary><span class="setup__btn">⚙ SETUP GUIDE</span></summary>
          <div class="ow">
            <div class="ow__ttl">Advanced Options</div>
            {setup(c).map((r: any) => (
              <div class="ow__row">
                <span class="ow__lab">{r.label}</span>
                {r.toggle
                  ? <span class={'ow__tg ' + (r.value === 'ON' ? 'on' : 'off')}>
                      {r.value === 'ON' && <i>ON</i>}
                      <b></b>
                      {r.value === 'OFF' && <i>OFF</i>}
                    </span>
                  : <span class="ow__sel">{r.value}<svg viewBox="0 0 16 16" class="ow__cv"><path d="M3 5l5 6 5-6z"/></svg></span>}
              </div>
            ))}
            <div class="ow__note">Everything is always mirrored. Everything else: tournament defaults.</div>
          </div>
        </details>
        <div class="cfg__hd">
          <span class="cfg__name">{c.group}{c.variant ? ` · ${c.variant}` : ''}</span>
          <span class="cfg__chips">
            {c.setting.split(' · ').map((p: string) => (<span class="ch">{p}</span>))}
          </span>
        </div>
        <div class="pills">
          <div class="pill">
            <div class="pill__l">City sites</div>
            <div class="pill__v"><b>{c.dist.sites?.mean ?? '—'}</b> <span class="pm">±{c.dist.sites?.sd ?? 0}</span></div>
            <div class="pill__r">min {c.dist.sites?.min} · <b>med {c.dist.sites?.med}</b> · max {c.dist.sites?.max}</div>
          </div>
          <div class="pill">
            <div class="pill__l">Land hex distance</div>
            {c.dist.land ? (<>
              <div class="pill__v"><b>{c.dist.land.mean}</b> <span class="pm">±{c.dist.land.sd}</span></div>
              <div class="pill__r">min {c.dist.land.min} · <b>med {c.dist.land.med}</b> · max {c.dist.land.max}</div>
            </>) : <div class="pill__v dash">—</div>}
          </div>
          <div class="pill">
            <div class="pill__l">Avg reachable</div>
            <div class="pill__v"><b>{c.reachMean ?? '—'}</b><span class="pm">%</span></div>
          </div>
        </div>
        <details class="gal" open>
          <summary>{Math.min(c.imgs.length, 21)} generated maps</summary>
          <div class="gal__grid">
            {c.imgs.slice(0, 21).map((p: string) => {
              const id = idFromImg(c.slug, p);
              const gm = genMap[id] || {};
              return (
                <a class="gal__cell" href={`${baseUrl}gen/${id}`} target="_blank" rel="noopener">
                  <img src={`${baseUrl}img/${p}`} loading="lazy" alt={`${c.group} sample`} />
                  <div class="cap">
                    <span><i>sites</i><b>{gm.sites ?? '—'}</b></span>
                    <span><i>land</i><b>{gm.land ?? '—'}</b></span>
                    <span><i>reach</i><b>{gm.reach != null ? gm.reach + '%' : '—'}</b></span>
                  </div>
                </a>
              );
            })}
          </div>
        </details>
      </div>
    ))}
  </div>

  <p class="note">
    {pool.length} of {dist.configCount} voted configs · {N} seeds each.
    Pool is land-connected by construction; split-dropped % is how often a
    seed had no connected symmetric pair. Targets (not gates): 18–22 city
    sites, ~45–65 land-hex capital distance. Vote tally from
    notes/ballots.txt via scripts/tally_votes.py.
  </p>

  <style>
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:80ch; margin:0.6rem 0 1.4rem; }
    .pool { display:flex; flex-direction:column; gap:0.8rem; }
    .cfg { position:relative; display:flex; flex-direction:column;
      background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.8rem 1rem; }
    .cfg__hd { order:0; display:flex; align-items:baseline; gap:0.8rem;
      flex-wrap:wrap; padding-right:10.5rem; }
    .pills { order:1; }
    .setup { order:2; }
    .gal { order:3; }
    .cfg__name { font-family:var(--font-display); font-weight:700;
      font-size:1.18rem; color:var(--text); }
    .cfg__chips { display:inline-flex; gap:0.35rem; flex-wrap:wrap; }
    .ch { font-family:var(--font-display); font-weight:700;
      font-size:0.84rem; color:var(--gold);
      background:linear-gradient(#15160f,#0c0d09);
      border:1px solid #4a431f; border-radius:6px;
      padding:0.1rem 0.55rem; box-shadow:inset 0 0 0 1px #000; }
    .snav { position:fixed; left:max(8px, calc((100vw - 1180px)/2 - 188px));
      top:104px; width:180px; display:flex; flex-direction:column;
      gap:0.1rem; max-height:calc(100vh - 130px); overflow:auto; z-index:20; }
    @media (max-width:1360px){ .snav{ left:8px; } }
    @media (max-width:1040px){ .snav{ position:static; width:auto;
      flex-flow:row wrap; max-height:none; margin-bottom:1rem; } }
    .snav__t { font-size:0.6rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-dim);
      margin-bottom:0.35rem; }
    .snav__l { display:block; color:var(--text-soft); text-decoration:none;
      font-size:0.78rem; padding:0.16rem 0.4rem; border-radius:4px;
      border-left:2px solid transparent; }
    .snav__l:hover { color:var(--gold); background:var(--bg-elev);
      text-decoration:none; }
    .snav__l.on { color:var(--gold); font-weight:700;
      border-left-color:var(--gold); background:var(--bg-elev); }
    .pills { display:flex; flex-wrap:wrap; gap:0.7rem; margin-top:0.7rem; }
    .pill { flex:1 1 240px; background:#16181d;
      border:1px solid var(--gold-deep); border-radius:8px;
      padding:0.55rem 0.85rem; }
    .pill__l { font-size:0.62rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-dim); }
    .pill__v { font-size:2.4rem; font-family:var(--font-display);
      font-weight:700; color:var(--gold); line-height:1.15;
      margin:0.05rem 0 0.1rem; }
    .pill__v .pm { font-size:0.95rem; color:var(--text-faint);
      font-family:var(--font-ui); font-weight:400; }
    .pill__v.dash { color:var(--text-dim); }
    .pill__r { font-size:0.72rem; color:var(--text-faint);
      font-family:var(--font-mono); }
    .pill__r b { color:var(--text-soft); }
    /* ---- SETUP GUIDE (in-game settings mock) ---- */
    .setup > summary { list-style:none; cursor:pointer;
      position:absolute; top:0.8rem; right:1rem; z-index:3;
      user-select:none; }
    .setup > summary::-webkit-details-marker { display:none; }
    .setup__btn { display:inline-block; font-family:var(--font-display);
      font-weight:700; font-size:0.86rem; letter-spacing:0.06em;
      color:var(--gold); background:linear-gradient(#231f0d,#1a1709);
      border:1px solid var(--gold-deep); border-radius:6px;
      padding:0.3rem 0.75rem; box-shadow:0 1px 3px #0008; }
    .setup > summary:hover .setup__btn { background:#2e2810;
      border-color:var(--gold-soft); }
    .setup[open] .setup__btn { background:#2e2810;
      border-color:var(--gold-soft); }
    .ow { margin:0.2rem 0 0.6rem; max-width:560px;
      background:radial-gradient(120% 140% at 50% 0%,#1c1d18,#0c0d0a);
      border:1px solid var(--gold-deep);
      border-radius:8px; padding:0.6rem 1rem 0.9rem;
      box-shadow:inset 0 0 40px rgba(0,0,0,0.6); }
    .ow__ttl { font-family:var(--font-display); font-weight:700;
      font-size:1.15rem; letter-spacing:0.12em; text-transform:uppercase;
      color:var(--gold); text-align:center; padding:0.3rem 0 0.5rem;
      text-shadow:0 1px 2px #000; }
    .ow__row { display:flex; align-items:center; justify-content:space-between;
      gap:1rem; padding:0.42rem 0.2rem; border-bottom:1px solid #00000055; }
    .ow__row:last-of-type { border-bottom:0; }
    .ow__lab { font-family:var(--font-ui); font-weight:600;
      font-size:0.9rem; color:#cdc6b4; text-shadow:0 1px 1px #000; }
    .ow__sel { display:inline-flex; align-items:center; justify-content:space-between;
      min-width:220px; gap:0.6rem; font-family:var(--font-display);
      font-weight:700; font-size:1.05rem; color:var(--gold);
      background:linear-gradient(#15160f,#0c0d09);
      border:1px solid #4a431f; border-radius:6px;
      padding:0.34rem 0.7rem; box-shadow:inset 0 0 0 1px #000; }
    .ow__cv { width:15px; height:15px; fill:var(--gold-soft); flex:none; }
    .ow__tg { display:inline-flex; align-items:center; gap:0.45rem;
      width:96px; height:30px; padding:0 0.4rem; border-radius:999px;
      border:1px solid #4a431f; box-shadow:inset 0 1px 4px #000;
      font-family:var(--font-ui); font-weight:800; font-size:0.7rem;
      letter-spacing:0.08em; }
    .ow__tg b { width:20px; height:20px; border-radius:50%;
      background:radial-gradient(circle at 35% 30%,#d8cdab,#7d7448);
      border:1px solid #000; flex:none; }
    .ow__tg.on  { background:linear-gradient(#1e7a5a,#125c43);
      color:#d8f3e7; justify-content:flex-start; }
    .ow__tg.off { background:linear-gradient(#2a2622,#171411);
      color:#8a8275; justify-content:flex-end; }
    .ow__note { font-size:0.72rem; color:var(--text-faint);
      font-family:var(--font-ui); margin-top:0.6rem; line-height:1.45; }
    .gal { margin-top:0.5rem; }
    .gal > summary { cursor:pointer; font-size:0.78rem;
      color:var(--gold-soft); font-family:var(--font-ui);
      padding:0.25rem 0; user-select:none; }
    .gal > summary:hover { color:var(--gold); }
    .gal__grid { display:grid; gap:0.5rem; margin-top:0.5rem;
      grid-template-columns:repeat(3,1fr); }
    @media (max-width:760px){ .gal__grid{ grid-template-columns:1fr 1fr; } }
    .gal__cell { display:block; border-radius:4px; overflow:hidden;
      border:1px solid var(--border-strong); }
    .gal__cell:hover { border-color:var(--gold); }
    .gal__grid img { width:100%; height:auto; display:block; }
    .cap { display:grid; grid-template-columns:1fr 1fr 1fr;
      background:#0e0f12; font-size:0.66rem; }
    .cap span { display:flex; flex-direction:column; align-items:center;
      padding:0.18rem 0; border-right:1px solid var(--border);
      color:var(--text-soft); }
    .cap span:last-child { border-right:0; }
    .cap i { font-style:normal; font-size:0.54rem; color:var(--text-dim);
      text-transform:uppercase; letter-spacing:0.05em; }
    .cap b { color:var(--text); font-size:0.84rem; }
    .note { font-size:0.8rem; color:var(--text-faint); line-height:1.5;
      max-width:84ch; margin-top:1.6rem; }
  </style>

  <script is:inline>
    (function(){
      var links=[].slice.call(document.querySelectorAll('.snav__l'));
      var secs=links.map(function(l){
        return document.getElementById('cfg-'+l.getAttribute('data-slug')); });
      function spy(){
        var best=0, bt=-1e9;
        secs.forEach(function(s,i){
          if(!s) return;
          var t=s.getBoundingClientRect().top-110;
          if(t<=0 && t>bt){ bt=t; best=i; }
        });
        links.forEach(function(l,i){ l.classList.toggle('on', i===best); });
      }
      window.addEventListener('scroll',function(){
        window.requestAnimationFrame(spy); },{passive:true});
      spy();
    })();
  </script>
</Base>
