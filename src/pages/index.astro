---
import Base from '../layouts/Base.astro';
import dist from '../data/atlas-dist.json';
import gensData from '../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

// The Round-2-voted tournament pool — 8 voters (incl. organiser,
// frederik's Round-1 votes ported for the Previously-Considered
// configs he didn't re-vote), scored +2 like / 0 maybe / −1 no.
//
// S = locked from Round 1 (unanimous in Round 1, kept regardless).
// A = strong R2 consensus, score +9 to +11 (5–6 likes of 8).
// B = solid R2 picks, score +7 to +8, rounding out the map types.
// Round 1 pool archived at /round-1; Round 2 ballot at /round-2.
const TIERS: { key: string; title: string; sub: string; slugs: string[] }[] = [
  { key: 'S', title: 'S — Locked from Round 1',
    sub: 'Unanimous in Round 1, kept regardless of Round 2.',
    slugs: [
      'arid-plateau-small-seas-smallest-square-sym',
      'coastal-rain-basin-smallest-wide-nosym',
      'dota-jungle-smallest-square-sym',
      'inland-sea-smallest-square-sym',
    ] },
  { key: 'A', title: 'A — Round 2 strong consensus',
    sub: 'Voted +9 to +11 in Round 2 (5–6 likes of 8).',
    slugs: [
      'arid-plateau-small-seas-smallest-wide-nosym',
      'inland-sea-smallest-wide-nosym',
      'archipelago-land-lg-water-sm-smallest-square-sym',
      'dota-jungle-smallest-wide-sym',
      'dota-sand-smallest-square-sym',
      'desert-lush-std-tiny-square-nosym',
    ] },
  { key: 'B', title: 'B — Round 2 variety',
    sub: 'Voted +6 to +8 in Round 2; round out the map-type variety.',
    slugs: [
      'continent-smallest-wide-sym',
      'desert-none-std-tiny-square-sym',
      'donut-irreg-low-smallest-square-sym',
      'wetlands-smallest-square-sym',
      'arid-plateau-large-seas-smallest-square-sym',
      'hardwood-forest-smallest-wide-nosym',
      'dota-water-smallest-square-sym',
      'mountain-pass-smallest-wide-sym',
    ] },
];
const TIER_OF: Record<string, string> = {};
for (const t of TIERS) for (const s of t.slugs) TIER_OF[s] = t.key;

const genMap: Record<string, any> = {};
for (const gn of (gensData as any).gens)
  genMap[gn.id] = { sites: gn.sites, land: gn.land, conn: gn.conn,
    reach: gn.reachPct, split: gn.split };
const idFromImg = (slug: string, p: string) => {
  const m = p.match(/seed-(\d+)/); return `${slug}-s${m ? m[1] : 1}`;
};

const sizeOf = (c: any) =>
  (c.setting || '').split(' · ')[0] === 'Tiny' ? 'Tiny' : 'Duel';
// sidebar / title text: group + variant + size (so the two Continents,
// and any future same-script doubles, are distinguishable)
const navName = (c: any) =>
  `${c.group}${c.variant ? ` · ${c.variant}` : ''} · ${sizeOf(c)}`;
const bySlug: Record<string, any> = {};
for (const c of dist.configs) bySlug[c.slug] = c;
// resolved sections: each tier's configs, sorted by map name within it
const sections = TIERS.map((t) => ({
  ...t,
  cfgs: t.slugs
    .map((s) => bySlug[s])
    .filter(Boolean)
    .sort((a: any, b: any) => navName(a).localeCompare(navName(b))),
}));
const pool = sections.flatMap((s) => s.cfgs);
const N = pool[0]?.n ?? 0;

// ---- Distribution charts ---------------------------------------------
// Per-seed values for the pool, straight from gens.json (the per-map
// source of truth). Powers the pool-wide bar chart at the top and the
// per-config unit dot-histograms above each gallery.
const POOL_SLUGS = new Set(pool.map((c: any) => c.slug));
type MK = 'sites' | 'water' | 'land' | 'slLand' | 'slSea';
type GP = { id: string; slug: string; label: string; seed: number;
  sites: number; water: number; land: number; slLand: number;
  slSea: number };
const poolGens: GP[] = ((gensData as any).gens as any[])
  .filter((gn) => POOL_SLUGS.has(gn.cslug))
  .map((gn) => ({ id: gn.id, slug: gn.cslug, label: gn.label,
    seed: gn.seed, sites: gn.sites, water: gn.water, land: gn.land,
    slLand: gn.slLand, slSea: gn.slSea }));
// Full multi-metric hover line, shared by bars + per-config dots.
const tipOf = (g: GP) =>
  `${g.label} · seed ${g.seed} — ${g.sites} sites · ${g.water} water-hex · `
  + `${g.land} land-hex · ${g.slLand} land-turns · ${g.slSea} water-turns`;

// Chart roster (drives both the pool bars and per-config dots, in
// order). Captions are purely descriptive — what each metric measures,
// not whether a value is "good"; the group hasn't defined that.
const METRICS: { key: MK; name: string; step: number; cap: string }[] = [
  { key: 'sites', name: 'City sites', step: 1,
    cap: 'Number of valid city sites placed on the map.' },
  { key: 'water', name: 'Water-route hexes', step: 5,
    cap: 'Cap→cap shortest path with embark allowed, in hex tiles (no move cost).' },
  { key: 'land', name: 'Land hex distance', step: 5,
    cap: 'Cap→cap shortest land-only path, in hex tiles.' },
  { key: 'slLand', name: 'Land move-cost (turns)', step: 5,
    cap: 'Army (move-2) cap→cap, terrain move-cost weighted, land only — in turns.' },
  { key: 'slSea', name: 'Water move-cost (turns)', step: 5,
    cap: 'Army (move-2) cap→cap, move-cost weighted, embark allowed — in turns.' },
];

type Bin = { x0: number; x1: number; label: string; cells: GP[] };
function bins(items: GP[], key: MK, step: number): Bin[] {
  if (!items.length) return [];
  const vals = items.map((i) => i[key]);
  const lo = Math.min(...vals), hi = Math.max(...vals);
  const start = Math.floor(lo / step) * step;
  const out: Bin[] = [];
  for (let x = start; x <= hi; x += step) {
    const cells = items
      .filter((i) => i[key] >= x && i[key] < x + step)
      .sort((a, b) => a[key] - b[key] || a.seed - b.seed);
    out.push({ x0: x, x1: x + step,
      label: step === 1 ? String(x) : `${x}–${x + step - 1}`, cells });
  }
  return out;
}
// Colour = distance from the mean in std-devs of whatever set is being
// charted (pool for the top bars, the config's own seeds for the
// per-config dots). |z| ≤1 green · ≤2 yellow · ≤3 orange · >3 red.
type Stat = { m: number; s: number };
function stat(vals: number[]): Stat {
  const n = vals.length || 1;
  const m = vals.reduce((a, b) => a + b, 0) / n;
  const s = Math.sqrt(vals.reduce((a, b) => a + (b - m) ** 2, 0) / n);
  return { m, s };
}
const zClass = (v: number, st: Stat) => {
  if (!st.s) return 'z-good';
  const z = Math.abs((v - st.m) / st.s);
  return z <= 1 ? 'z-good' : z <= 2 ? 'z-ok' : z <= 3 ? 'z-edge' : 'z-bad';
};
const maxN = (bs: Bin[]) => Math.max(1, ...bs.map((b) => b.cells.length));
// Pool mean/sd per metric, computed once. The per-config dots colour
// off the SAME pool stats as the top bars so a colour means the same
// thing everywhere (cross-config comparable, not self-normalised).
const poolStat = Object.fromEntries(
  (['sites', 'water', 'land', 'slLand', 'slSea'] as MK[]).map((k) =>
    [k, stat(poolGens.map((g) => g[k]))])) as Record<MK, Stat>;

// ---- In-game SETUP GUIDE ---------------------------------------------
// The exact New Game → Advanced Options to set so the in-game generator
// reproduces this config. Universal four (Size/Aspect/Point-Sym/Mirror)
// are parsed from c.setting; the script + its map-options come from
// owmapgen-lab/scripts/configs.py (single source of truth).
const SCRIPT_NAME: Record<string, string> = {
  'Continent': 'Continent',
  'Coastal Rain Basin': 'Coastal Rain Basin',
  'Donut': 'Donut',
  'Archipelago': 'Archipelago',
  'Arid Plateau': 'Arid Plateau',
  'DOTA': 'Duel of the Ancients',
  'Hardwood Forest': 'Hardwood Forest',
  'Inland Sea': 'Inland Sea',
  'Desert': 'Lush Desert',
  'Mountain Pass': 'Mountain Pass',
  'Highlands': 'Highlands',
};
// keyed by `${group}|${variant}` — script-specific dropdowns to change
const SCRIPT_OPTS: Record<string, [string, string][]> = {
  'Arid Plateau|Small Seas': [['Arid Water Size', 'Small']],
  'Arid Plateau|Large Seas': [['Arid Water Size', 'Large']],
  'Coastal Rain Basin|': [],
  'DOTA|Jungle': [['Separating Terrain', 'Jungle']],
  'DOTA|Sand': [['Separating Terrain', 'Sand']],
  'DOTA|Water': [['Separating Terrain', 'Water']],
  'Inland Sea|': [],
  'Continent|': [['Continent Terrain', 'None']],
  'Hardwood Forest|': [],
  'Archipelago|Land Lg · Water Sm': [
    ['Archipelago Landmass', 'Large'],
    ['Archipelago Water Size', 'Merged']],
  'Desert|Lush · Std': [['Desert Coast', 'Lush'], ['Desert Size', 'Standard']],
  'Desert|None · Std': [['Desert Coast', 'None'], ['Desert Size', 'Standard']],
  'Desert|Dry · Std': [['Desert Coast', 'Dry'], ['Desert Size', 'Standard']],
  'Donut|Irreg Low': [['Donut Irregularity', 'Low']],
  'Mountain Pass|': [],
  'Highlands|': [],
};
type Row = { label: string; value: string; toggle?: boolean };
function setup(c: any): Row[] {
  const p = (c.setting || '').split(' · ');           // Duel · square · point-sym on · mirror
  const aspect = (p[1] || 'square');
  const sym = (p[2] || '').includes('on');
  const rows: Row[] = [
    { label: 'Map Script', value: SCRIPT_NAME[c.group] || c.group },
    { label: 'Map Size', value: p[0] === 'Tiny' ? 'Tiny' : 'Duel' },
    { label: 'Map Aspect Ratio',
      value: aspect.charAt(0).toUpperCase() + aspect.slice(1) },
  ];
  for (const [l, v] of (SCRIPT_OPTS[`${c.group}|${c.variant || ''}`] || []))
    rows.push({ label: l, value: v });
  rows.push({ label: 'Point Symmetry', value: sym ? 'ON' : 'OFF', toggle: true });
  rows.push({ label: 'Mirror Map', value: 'ON', toggle: true });
  return rows;
}
---
<Base title="Tournament Pool">
  <p class="lede">
    The <b>{pool.length} maps</b> for the tournament — the Round-2 vote
    pool (8 voters). 4 carried over locked from Round 1 (unanimous),
    14 added or re-affirmed in Round 2 (incl. DOTA Water and Mountain
    Pass at +6, organiser adds for script variety). Round 1 pool
    archived at <a href={`${baseUrl}round-1`}>/round-1</a>.
  </p>

  <section class="dist">
    <div class="dist__h">
      <h2 class="dist__t">Pool distribution</h2>
      <span class="dist__sub">{poolGens.length} maps across {pool.length} configs · click a bar for its maps</span>
      <span class="dist__leg">colour = σ from mean
        <i class="z-good"></i>≤1
        <i class="z-ok"></i>≤2
        <i class="z-edge"></i>≤3
        <i class="z-bad"></i>&gt;3</span>
    </div>
    <div class="dist__grid">
      {METRICS.map((ch) => {
        const bs = bins(poolGens, ch.key, ch.step);
        const mx = maxN(bs);
        const st = poolStat[ch.key];
        return (
          <div class="chart">
            <div class="chart__t">{ch.name}</div>
            <div class="bars">
              {bs.map((b) => {
                const mid = ch.step === 1 ? b.x0 : b.x0 + ch.step / 2;
                return (
                  <details class="hb">
                    <summary class={'bar ' + zClass(mid, st)}
                      title={`${b.label}: ${b.cells.length} maps`}
                      style={`--h:${Math.round(b.cells.length / mx * 116) + (b.cells.length ? 4 : 0)}px`}>
                      <span class="bar__n">{b.cells.length || ''}</span>
                      <span class="bar__f"></span>
                      <span class="bar__x">{b.label}</span>
                    </summary>
                    <div class="pop">
                      <div class="pop__h">{b.label} · {b.cells.length} maps</div>
                      <div class="pop__l">
                        {b.cells.map((g) => (
                          <a href={`${baseUrl}gen/${g.id}`} target="_blank"
                             rel="noopener" title={tipOf(g)}>
                            {g.label.split(' · ')[0]} <i>s{g.seed}</i>
                          </a>
                        ))}
                      </div>
                    </div>
                  </details>
                );
              })}
            </div>
            <div class="chart__cap">{ch.cap}</div>
          </div>
        );
      })}
    </div>
  </section>

  <nav class="snav" id="snav">
    {sections.map((sec: any) => (
      <div class="snav__sec">
        <div class="snav__t">{sec.title}</div>
        {sec.cfgs.map((c: any) => (
          <a class="snav__l" data-slug={c.slug} href={`#cfg-${c.slug}`}
             title={c.label}>{navName(c)}</a>
        ))}
      </div>
    ))}
  </nav>

  <div class="pool">
    {sections.map((sec: any) => (
      <section class="tier" id={`tier-${sec.key}`}>
        <div class="tier__h">
          <h2 class="tier__t">{sec.title}</h2>
          <span class="tier__sub">{sec.sub}</span>
          <span class="tier__n">{sec.cfgs.length} maps</span>
        </div>
        {sec.cfgs.map((c: any) => (
      <div class="cfg" id={`cfg-${c.slug}`}>
        <details class="setup">
          <summary><span class="setup__btn">⚙ SETUP GUIDE</span></summary>
          <div class="ow">
            <div class="ow__ttl">Advanced Options</div>
            {setup(c).map((r: any) => (
              <div class="ow__row">
                <span class="ow__lab">{r.label}</span>
                {r.toggle
                  ? <span class={'ow__tg ' + (r.value === 'ON' ? 'on' : 'off')}>
                      {r.value === 'ON' && <i>ON</i>}
                      <b></b>
                      {r.value === 'OFF' && <i>OFF</i>}
                    </span>
                  : <span class="ow__sel">{r.value}<svg viewBox="0 0 16 16" class="ow__cv"><path d="M3 5l5 6 5-6z"/></svg></span>}
              </div>
            ))}
            <div class="ow__note">Everything is always mirrored. Everything else: tournament defaults.</div>
          </div>
        </details>
        <div class="cfg__hd">
          <span class="cfg__name">{navName(c)}</span>
          <span class="cfg__chips">
            {c.setting.split(' · ').map((p: string) => (<span class="ch">{p}</span>))}
          </span>
        </div>
        <div class="pills">
          <div class="pill">
            <div class="pill__l">City sites</div>
            <div class="pill__v"><b>{c.dist.sites?.mean ?? '—'}</b> <span class="pm">±{c.dist.sites?.sd ?? 0}</span></div>
            <div class="pill__r">min {c.dist.sites?.min} · <b>med {c.dist.sites?.med}</b> · max {c.dist.sites?.max}</div>
          </div>
          <div class="pill">
            <div class="pill__l">Land hex distance</div>
            {c.dist.land ? (<>
              <div class="pill__v"><b>{c.dist.land.mean}</b> <span class="pm">±{c.dist.land.sd}</span></div>
              <div class="pill__r">min {c.dist.land.min} · <b>med {c.dist.land.med}</b> · max {c.dist.land.max}</div>
            </>) : <div class="pill__v dash">—</div>}
          </div>
          <div class="pill">
            <div class="pill__l">Avg reachable</div>
            <div class="pill__v"><b>{c.reachMean ?? '—'}</b><span class="pm">%</span></div>
          </div>
        </div>
        {(() => {
          const cg = poolGens.filter((g) => g.slug === c.slug);
          return (
            <div class="cfgdist">
              {METRICS.map((ch) => {
                const st = poolStat[ch.key];
                return (
                <div class="cd">
                  <div class="cd__t">{ch.name}<span>{cg.length} maps · click a square</span></div>
                  <div class="cd__cols">
                    {bins(cg, ch.key, ch.step).map((b) => {
                      return (
                        <div class="cd__col">
                          <div class="cd__stack">
                            {b.cells.map((g) => (
                              <a class={'dot ' + zClass(g[ch.key], st)}
                                href={`${baseUrl}gen/${g.id}`}
                                target="_blank" rel="noopener"
                                title={tipOf(g)}></a>
                            ))}
                          </div>
                          <span class="cd__x">{b.label}</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
                );
              })}
            </div>
          );
        })()}
        <details class="gal" open>
          <summary>{Math.min(c.imgs.length, 21)} generated maps</summary>
          <div class="gal__grid">
            {c.imgs.slice(0, 21).map((p: string) => {
              const id = idFromImg(c.slug, p);
              const gm = genMap[id] || {};
              return (
                <a class="gal__cell" href={`${baseUrl}gen/${id}`} target="_blank" rel="noopener">
                  <img src={`${baseUrl}img/${p}`} loading="lazy" alt={`${c.group} sample`} />
                  <div class="cap">
                    <span><i>sites</i><b>{gm.sites ?? '—'}</b></span>
                    <span><i>land</i><b>{gm.land ?? '—'}</b></span>
                    <span><i>reach</i><b>{gm.reach != null ? gm.reach + '%' : '—'}</b></span>
                  </div>
                </a>
              );
            })}
          </div>
        </details>
      </div>
        ))}
      </section>
    ))}
  </div>

  <p class="note">
    {pool.length} configs · {N}-ish seeds each. Pool is land-connected
    by construction; split-dropped % is how often a seed had no
    connected symmetric pair. Charts are descriptive — colour is
    std-devs from each set's mean, not a judgement of what's good.
    Round 2 vote (8 voters, scored +2 like / 0 maybe / −1 no, organiser
    included, frederik's Round 1 votes ported for configs he didn't
    re-vote). Round 1 archive: <a href={`${baseUrl}round-1`}>/round-1</a>.
  </p>

  <style>
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:80ch; margin:0.6rem 0 1.4rem; }
    .pool { display:flex; flex-direction:column; gap:2rem; }
    .tier { display:flex; flex-direction:column; gap:0.8rem; }
    .tier__h { display:flex; align-items:baseline; gap:0.7rem;
      flex-wrap:wrap; border-bottom:1px solid var(--gold-deep);
      padding-bottom:0.35rem; }
    .tier__t { font-family:var(--font-display); font-weight:700;
      font-size:1.55rem; color:var(--gold); }
    .tier__sub { font-family:var(--font-display); font-style:italic;
      font-size:0.92rem; color:var(--text-faint); }
    .tier__n { margin-left:auto; font-size:0.68rem;
      font-family:var(--font-mono); color:var(--text-dim);
      letter-spacing:0.08em; }
    .cfg { position:relative; display:flex; flex-direction:column;
      background:var(--bg-elev); border:1px solid var(--border);
      border-radius:6px; padding:0.8rem 1rem; }
    .cfg__hd { order:0; display:flex; align-items:baseline; gap:0.8rem;
      flex-wrap:wrap; padding-right:10.5rem; }
    .pills { order:1; }
    .cfgdist { order:2; }
    .setup { order:3; }
    .gal { order:4; }
    .cfg__name { font-family:var(--font-display); font-weight:700;
      font-size:1.18rem; color:var(--text); }
    .cfg__chips { display:inline-flex; gap:0.35rem; flex-wrap:wrap; }
    .ch { font-family:var(--font-display); font-weight:700;
      font-size:0.84rem; color:var(--gold);
      background:linear-gradient(#15160f,#0c0d09);
      border:1px solid #4a431f; border-radius:6px;
      padding:0.1rem 0.55rem; box-shadow:inset 0 0 0 1px #000; }
    .snav { position:fixed; left:max(8px, calc((100vw - 1180px)/2 - 188px));
      top:104px; width:180px; display:flex; flex-direction:column;
      gap:0.1rem; max-height:calc(100vh - 130px); overflow:auto; z-index:20; }
    @media (max-width:1360px){ .snav{ left:8px; } }
    @media (max-width:1040px){ .snav{ position:static; width:auto;
      flex-flow:row wrap; max-height:none; margin-bottom:1rem; } }
    .snav__sec { margin-bottom:0.7rem; }
    .snav__t { font-size:0.64rem; letter-spacing:0.12em;
      text-transform:uppercase; color:var(--gold-soft);
      margin-bottom:0.3rem; font-weight:700; }
    .snav__l { display:block; color:var(--text-soft); text-decoration:none;
      font-size:0.78rem; padding:0.16rem 0.4rem; border-radius:4px;
      border-left:2px solid transparent; }
    .snav__l:hover { color:var(--gold); background:var(--bg-elev);
      text-decoration:none; }
    .snav__l.on { color:var(--gold); font-weight:700;
      border-left-color:var(--gold); background:var(--bg-elev); }
    .pills { display:flex; flex-wrap:wrap; gap:0.7rem; margin-top:0.7rem; }
    .pill { flex:1 1 240px; background:#16181d;
      border:1px solid var(--gold-deep); border-radius:8px;
      padding:0.55rem 0.85rem; }
    .pill__l { font-size:0.62rem; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-dim); }
    .pill__v { font-size:2.4rem; font-family:var(--font-display);
      font-weight:700; color:var(--gold); line-height:1.15;
      margin:0.05rem 0 0.1rem; }
    .pill__v .pm { font-size:0.95rem; color:var(--text-faint);
      font-family:var(--font-ui); font-weight:400; }
    .pill__v.dash { color:var(--text-dim); }
    .pill__r { font-size:0.72rem; color:var(--text-faint);
      font-family:var(--font-mono); }
    .pill__r b { color:var(--text-soft); }
    /* ---- SETUP GUIDE (in-game settings mock) ---- */
    .setup > summary { list-style:none; cursor:pointer;
      position:absolute; top:0.8rem; right:1rem; z-index:3;
      user-select:none; }
    .setup > summary::-webkit-details-marker { display:none; }
    .setup__btn { display:inline-block; font-family:var(--font-display);
      font-weight:700; font-size:0.86rem; letter-spacing:0.06em;
      color:var(--gold); background:linear-gradient(#231f0d,#1a1709);
      border:1px solid var(--gold-deep); border-radius:6px;
      padding:0.3rem 0.75rem; box-shadow:0 1px 3px #0008; }
    .setup > summary:hover .setup__btn { background:#2e2810;
      border-color:var(--gold-soft); }
    .setup[open] .setup__btn { background:#2e2810;
      border-color:var(--gold-soft); }
    .ow { margin:0.2rem 0 0.6rem; max-width:560px;
      background:radial-gradient(120% 140% at 50% 0%,#1c1d18,#0c0d0a);
      border:1px solid var(--gold-deep);
      border-radius:8px; padding:0.6rem 1rem 0.9rem;
      box-shadow:inset 0 0 40px rgba(0,0,0,0.6); }
