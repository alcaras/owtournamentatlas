---
import Base from '../layouts/Base.astro';
import dist from '../data/atlas-dist.json';
import gensData from '../data/gens.json';
const baseUrl = import.meta.env.BASE_URL;

// The finalised tournament pool — 16 maps, organised by map script.
// Derived from the Round 1 unanimous locks + the Round 2 vote (8
// voters), trimmed of duplicate-script redundancy (Arid Plateau Small
// Seas and DOTA Jungle each had a 2nd variant cut for being a same-
// script duplicate). This page is the tournament reference.
const POOL: string[] = [
  // Archipelago (sq/sym + wide/nosym for axis+sym variety)
  'archipelago-land-lg-water-sm-smallest-square-sym',
  'archipelago-land-lg-water-sm-smallest-wide-nosym',
  // Arid Plateau (Small Seas + Large Seas)
  'arid-plateau-small-seas-smallest-square-sym',
  'arid-plateau-large-seas-smallest-square-sym',
  // Coastal Rain Basin (wide/nosym locked + sq/sym for sym variety)
  'coastal-rain-basin-smallest-wide-nosym',
  'coastal-rain-basin-smallest-square-sym',
  // Continent
  'continent-smallest-wide-sym',
  // Desert (Lush + No Coast)
  'desert-lush-std-tiny-square-nosym',
  'desert-none-std-tiny-square-sym',
  // Donut
  'donut-irreg-low-smallest-square-sym',
  // DOTA (Jungle, Sand, Water)
  'dota-jungle-smallest-square-sym',
  'dota-sand-smallest-square-sym',
  'dota-water-smallest-square-sym',
  // Hardwood Forest
  'hardwood-forest-smallest-wide-nosym',
  // Inland Sea
  'inland-sea-smallest-square-sym',
  'inland-sea-smallest-wide-nosym',
  // Mountain Pass
  'mountain-pass-smallest-wide-sym',
  // Wetlands
  'wetlands-smallest-square-sym',
];

const genMap: Record<string, any> = {};
for (const gn of (gensData as any).gens)
  genMap[gn.id] = { sites: gn.sites, land: gn.land, conn: gn.conn,
    reach: gn.reachPct, split: gn.split, slLand: gn.slLand };
const idFromImg = (slug: string, p: string) => {
  const m = p.match(/seed-(\d+)/); return `${slug}-s${m ? m[1] : 1}`;
};

const sizeOf = (c: any) =>
  (c.setting || '').split(' · ')[0] === 'Tiny' ? 'Tiny' : 'Duel';
// sidebar / title text: group + variant + size (so the two Continents,
// and any future same-script doubles, are distinguishable)
const navName = (c: any) =>
  `${c.group}${c.variant ? ` · ${c.variant}` : ''} · ${sizeOf(c)}`;
// Compact sidebar label — script name is in the section heading, so
// only show what differs between configs under that heading. For 1-cfg
// sections, fall back to full size · aspect · sym.  Title Case throughout.
const symOf = (c: any) =>
  ((c.setting || '').split(' · ')[2] || '').includes('on') ? 'Sym' : 'No-Sym';
const aspOf = (c: any) => {
  const a = (c.setting || '').split(' · ')[1] || '';
  return a ? a[0].toUpperCase() + a.slice(1) : '';
};
function navLabel(c: any, peers: any[]): string {
  if (peers.length <= 1) return `${sizeOf(c)} · ${aspOf(c)} · ${symOf(c)}`;
  const axes = [
    ['variant', (x: any) => x.variant || ''],
    ['size', sizeOf],
    ['aspect', aspOf],
    ['sym', symOf],
  ] as const;
  const parts: string[] = [];
  for (const [, fn] of axes) {
    const vals = new Set(peers.map(fn));
    if (vals.size > 1) {
      const v = fn(c);
      if (v) parts.push(v);
    }
  }
  return parts.join(' · ') || `${sizeOf(c)} · ${aspOf(c)} · ${symOf(c)}`;
}
const bySlug: Record<string, any> = {};
for (const c of dist.configs) bySlug[c.slug] = c;
const pool = POOL.map((s) => bySlug[s]).filter(Boolean);
const N = pool[0]?.n ?? 0;

// Group by map script — DOTA by subtype, Desert by coast, else the
// script. Sections are alphabetised; cfgs within a section sorted
// by full name so locked-and-2nd variants sit together.
const dg = (c: any) => {
  if (c.group === 'DOTA') return `DOTA · ${c.variant}`;
  if (c.group === 'Desert') {
    const coast = (c.variant || '').split(' · ')[0];
    return `Desert: ${coast === 'None' ? 'No' : coast} Coast`;
  }
  return c.group;
};
const groupMap: Record<string, any[]> = {};
for (const c of pool) (groupMap[dg(c)] ??= []).push(c);
const sections = Object.keys(groupMap)
  .sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()))
  .map((k) => ({
  key: k, title: k,
  cfgs: groupMap[k].sort((a: any, b: any) =>
    navName(a).localeCompare(navName(b))),
}));

// ---- Distribution charts ---------------------------------------------
// Per-seed values for the pool, straight from gens.json (the per-map
// source of truth). Powers the pool-wide bar chart at the top and the
// per-config unit dot-histograms above each gallery.
const POOL_SLUGS = new Set(pool.map((c: any) => c.slug));
type MK = 'sites' | 'water' | 'land' | 'slLand' | 'slSea';
type GP = { id: string; slug: string; label: string; seed: number;
  sites: number; water: number; land: number; slLand: number;
  slSea: number };
const poolGens: GP[] = ((gensData as any).gens as any[])
  .filter((gn) => POOL_SLUGS.has(gn.cslug))
  .map((gn) => ({ id: gn.id, slug: gn.cslug, label: gn.label,
    seed: gn.seed, sites: gn.sites, water: gn.water, land: gn.land,
    slLand: gn.slLand, slSea: gn.slSea }));
// Full multi-metric hover line, shared by bars + per-config dots.
const tipOf = (g: GP) =>
  `${g.label} · seed ${g.seed} — ${g.sites} sites · ${g.water} water-hex · `
  + `${g.land} land-hex · ${g.slLand} land-moves · ${g.slSea} water-moves`;

// Chart roster (drives both the pool bars and per-config dots, in
// order). Captions are purely descriptive — what each metric measures,
// not whether a value is "good"; the group hasn't defined that.
const METRICS: { key: MK; name: string; step: number; cap: string }[] = [
  { key: 'sites', name: 'City sites', step: 1,
    cap: 'Number of valid city sites placed on the map.' },
  { key: 'water', name: 'Water-route hexes', step: 5,
    cap: 'Cap→cap shortest path with embark allowed, in hex tiles (no move cost).' },
  { key: 'land', name: 'Land hex distance', step: 5,
    cap: 'Cap→cap shortest land-only path, in hex tiles.' },
  { key: 'slLand', name: 'Land move-cost (moves)', step: 5,
    cap: 'Army (move-2) cap→cap, terrain move-cost weighted, land only — in moves.' },
  { key: 'slSea', name: 'Water move-cost (moves)', step: 5,
    cap: 'Army (move-2) cap→cap, move-cost weighted, embark allowed — in moves.' },
];

type Bin = { x0: number; x1: number; label: string; cells: GP[] };
function bins(items: GP[], key: MK, step: number): Bin[] {
  if (!items.length) return [];
  const vals = items.map((i) => i[key]);
  const lo = Math.min(...vals), hi = Math.max(...vals);
  const start = Math.floor(lo / step) * step;
  const out: Bin[] = [];
  for (let x = start; x <= hi; x += step) {
    const cells = items
      .filter((i) => i[key] >= x && i[key] < x + step)
      .sort((a, b) => a[key] - b[key] || a.seed - b.seed);
    out.push({ x0: x, x1: x + step,
      label: step === 1 ? String(x) : `${x}–${x + step - 1}`, cells });
  }
  return out;
}
// Colour = distance from the mean in std-devs of whatever set is being
// charted (pool for the top bars, the config's own seeds for the
// per-config dots). |z| ≤1 green · ≤2 yellow · ≤3 orange · >3 red.
type Stat = { m: number; s: number };
function stat(vals: number[]): Stat {
  const n = vals.length || 1;
  const m = vals.reduce((a, b) => a + b, 0) / n;
  const s = Math.sqrt(vals.reduce((a, b) => a + (b - m) ** 2, 0) / n);
  return { m, s };
}
const zClass = (v: number, st: Stat) => {
  if (!st.s) return 'z-good';
  const z = Math.abs((v - st.m) / st.s);
  return z <= 1 ? 'z-good' : z <= 2 ? 'z-ok' : z <= 3 ? 'z-edge' : 'z-bad';
};
const maxN = (bs: Bin[]) => Math.max(1, ...bs.map((b) => b.cells.length));
// Pool mean/sd per metric, computed once. The per-config dots colour
// off the SAME pool stats as the top bars so a colour means the same
// thing everywhere (cross-config comparable, not self-normalised).
const poolStat = Object.fromEntries(
  (['sites', 'water', 'land', 'slLand', 'slSea'] as MK[]).map((k) =>
    [k, stat(poolGens.map((g) => g[k]))])) as Record<MK, Stat>;

// ---- In-game SETUP GUIDE ---------------------------------------------
// The exact New Game → Advanced Options to set so the in-game generator
// reproduces this config. Universal four (Size/Aspect/Point-Sym/Mirror)
// are parsed from c.setting; the script + its map-options come from
// owmapgen-lab/scripts/configs.py (single source of truth).
const SCRIPT_NAME: Record<string, string> = {
  'Continent': 'Continent',
  'Coastal Rain Basin': 'Coastal Rain Basin',
  'Donut': 'Donut',
  'Archipelago': 'Archipelago',
  'Arid Plateau': 'Arid Plateau',
  'DOTA': 'Duel of the Ancients',
  'Hardwood Forest': 'Hardwood Forest',
  'Inland Sea': 'Inland Sea',
  'Desert': 'Lush Desert',
  'Mountain Pass': 'Mountain Pass',
  'Highlands': 'Highlands',
};
// keyed by `${group}|${variant}` — script-specific dropdowns to change
const SCRIPT_OPTS: Record<string, [string, string][]> = {
  'Arid Plateau|Small Seas': [['Arid Water Size', 'Small']],
  'Arid Plateau|Large Seas': [['Arid Water Size', 'Large']],
  'Coastal Rain Basin|': [],
  'DOTA|Jungle': [['Separating Terrain', 'Jungle']],
  'DOTA|Sand': [['Separating Terrain', 'Sand']],
  'DOTA|Water': [['Separating Terrain', 'Water']],
  'Inland Sea|': [],
  'Continent|': [['Continent Terrain', 'None']],
  'Hardwood Forest|': [],
  'Archipelago|Land Lg · Water Sm': [
    ['Archipelago Landmass', 'Large'],
    ['Archipelago Water Size', 'Small']],
  'Desert|Lush · Std': [['Desert Coast', 'Lush'], ['Desert Size', 'Standard']],
  'Desert|None · Std': [['Desert Coast', 'None'], ['Desert Size', 'Standard']],
  'Desert|Dry · Std': [['Desert Coast', 'Dry'], ['Desert Size', 'Standard']],
  'Donut|Irreg Low': [['Donut Irregularity', 'Low']],
  'Mountain Pass|': [],
  'Highlands|': [],
};
type Row = { label: string; value: string; toggle?: boolean };
function setup(c: any): Row[] {
  const p = (c.setting || '').split(' · ');           // Duel · square · point-sym on · mirror
  const aspect = (p[1] || 'square');
  const sym = (p[2] || '').includes('on');
  const rows: Row[] = [
    { label: 'Map Script', value: SCRIPT_NAME[c.group] || c.group },
    { label: 'Map Size', value: p[0] === 'Tiny' ? 'Tiny' : 'Duel' },
    { label: 'Map Aspect Ratio',
      value: aspect.charAt(0).toUpperCase() + aspect.slice(1) },
  ];
  for (const [l, v] of (SCRIPT_OPTS[`${c.group}|${c.variant || ''}`] || []))
    rows.push({ label: l, value: v });
  rows.push({ label: 'Point Symmetry', value: sym ? 'ON' : 'OFF', toggle: true });
  rows.push({ label: 'Mirror Map', value: 'ON', toggle: true });
  return rows;
}

// ---- Resource strip --------------------------------------------------
// Per-config resource picture: an icon + a colour bar (green = lots,
// red = low) instead of a wall of numbers. Bar fill/colour is RELATIVE
// to the rest of the pool, so a glance answers "lots of iron here vs
// there". Exact mean ±sd is in the hover tooltip. (Design note from the
// organisers: fewer numbers — most eyes glaze over a stat wall.)
const RES_BARS = [
  { key: 'grain', icon: 'wheat', label: 'Grain',
    desc: 'Wheat / Barley / Sorghum (Farm)' },
  { key: 'pasture', icon: 'cattle', label: 'Pasture',
    desc: 'Cattle / Sheep / Pig / Goat / Horse' },
  { key: 'camp', icon: 'game', label: 'Camp',
    desc: 'Game / Fur / Elephant / Ivory / Camel / Exotic (worked by Camp)' },
  { key: 'grove', icon: 'wine', label: 'Grove',
    desc: 'Wine / Olive / Citrus / Honey / Lavender / Silk / Spices / Tea' },
  { key: 'nets', icon: 'fish', label: 'Nets',
    desc: 'Fish / Crab / Pearl / Dye (worked by Nets)' },
  { key: 'ore', icon: 'iron', label: 'Ore',
    desc: 'Ore (worked into iron)' },
  { key: 'precious', icon: 'gold', label: 'Precious',
    desc: 'Gold / Silver / Gem / Jade (precious goods)' },
  { key: 'marble', icon: 'stone', label: 'Marble',
    desc: 'Marble (worked into stone)' },
  { key: 'horse', icon: 'horse', label: 'Horses',
    desc: 'Horse resource' },
  { key: 'ele', icon: 'elephant', label: 'Elephants',
    desc: 'Elephant resource' },
  { key: 'camel', icon: 'camel', label: 'Camels',
    desc: 'Camel resource' },
] as const;
// pool min/max of each resource's per-config mean → normalisation range,
// so every bar reads "lots vs little of this RELATIVE to the other maps".
const resRange: Record<string, { lo: number; hi: number }> = {};
for (const b of RES_BARS) {
  const ms = pool.map((c: any) => c.dist?.[b.key]?.mean)
    .filter((v: any) => v != null);
  resRange[b.key] = { lo: ms.length ? Math.min(...ms) : 0,
    hi: ms.length ? Math.max(...ms) : 0 };
}
// per-config bar: t∈[0,1] vs the pool range → fill width + red→amber→green
const barOf = (c: any, key: string) => {
  const d = c.dist?.[key];
  const r = resRange[key] || { lo: 0, hi: 0 };
  const mean = d?.mean ?? 0;
  const t = r.hi > r.lo ? (mean - r.lo) / (r.hi - r.lo) : 0.5;
  const tt = Math.max(0, Math.min(1, t));
  return { d, t: tt, w: Math.round(8 + tt * 92),
    col: `hsl(${Math.round(tt * 125)},58%,42%)` };
};
const barTip = (b: any, d: any) =>
  `${b.label} — ${b.desc}\navg ${d?.mean ?? 0} per map (±${d?.sd ?? 0} sd, `
  + `range ${d?.min ?? 0}–${d?.max ?? 0}). Bar = relative to other maps.`;

// ---- hero-pill relative bars -----------------------------------------
// Same green→red language as the resource bars, applied to the headline
// stats so each pill also shows where this script sits vs the pool.
const PILL_KEYS = ['sites', 'land', 'slLand', 'expansion'] as const;
const pillRange: Record<string, { lo: number; hi: number }> = {};
for (const k of PILL_KEYS) {
  const ms = pool.map((c: any) => c.dist?.[k]?.mean)
    .filter((v: any) => v != null);
  pillRange[k] = { lo: ms.length ? Math.min(...ms) : 0,
    hi: ms.length ? Math.max(...ms) : 0 };
}
const barStyle = (mean: number | undefined, range: { lo: number; hi: number }) => {
  if (mean == null) return 'width:0%;background:#333';
  const t = range.hi > range.lo ? (mean - range.lo) / (range.hi - range.lo) : 0.5;
  const tt = Math.max(0, Math.min(1, t));
  return `width:${Math.round(8 + tt * 92)}%;background:hsl(${Math.round(tt * 125)},58%,42%)`;
};
---
<Base title="Tournament Pool" hideNav={true}>
  <p class="lede">
    The <b>{pool.length}-map tournament pool</b>, grouped by map script.
    The reference for in-game setup — pills show the live distribution
    of each config (city sites, distances, urban tiles), the resource
    bars show how rich each map runs in a resource <i>relative to the
    other maps</i> (hover for exact amounts), the SETUP GUIDE button
    gives the exact in-game Advanced Options, and the gallery shows
    generated samples. Hover or click any preview to inspect.
  </p>

  <nav class="snav" id="snav">
    <div class="rand">
      <button type="button" id="randPick" class="rand__btn">🎲 Random map</button>
      <span class="rand__hint" id="randHint"></span>
    </div>
    {sections.map((sec: any) => (
      <div class="snav__sec">
        <div class="snav__t">{sec.title}</div>
        {sec.cfgs.map((c: any) => (
          <a class="snav__l" data-slug={c.slug} href={`#cfg-${c.slug}`}
             title={c.label}>{navLabel(c, sec.cfgs)}</a>
        ))}
      </div>
    ))}
  </nav>

  <div class="pool">
    {sections.map((sec: any) => (
      <section class="tier" id={`s-${sec.key.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
        <div class="tier__h">
          <h2 class="tier__t">{sec.title}</h2>
          <span class="tier__n">{sec.cfgs.length === 1 ? '1 map' : `${sec.cfgs.length} maps`}</span>
        </div>
        {sec.cfgs.map((c: any) => (
      <div class="cfg" id={`cfg-${c.slug}`}>
        <details class="setup">
          <summary><span class="setup__btn">⚙ SETUP GUIDE</span></summary>
          <div class="ow">
            <div class="ow__ttl">Advanced Options</div>
            {setup(c).map((r: any) => (
              <div class="ow__row">
                <span class="ow__lab">{r.label}</span>
                {r.toggle
                  ? <span class={'ow__tg ' + (r.value === 'ON' ? 'on' : 'off')}>
                      {r.value === 'ON' && <i>ON</i>}
                      <b></b>
                      {r.value === 'OFF' && <i>OFF</i>}
                    </span>
                  : <span class="ow__sel">{r.value}<svg viewBox="0 0 16 16" class="ow__cv"><path d="M3 5l5 6 5-6z"/></svg></span>}
              </div>
            ))}
            <div class="ow__note">Everything is always mirrored. Everything else: tournament defaults.</div>
          </div>
        </details>
        <div class="cfg__hd">
          <span class="cfg__name">{navName(c)}</span>
          <span class="cfg__chips">
            {c.setting.split(' · ').map((p: string) => (<span class="ch">{p}</span>))}
          </span>
        </div>
        <div class="pills">
          <div class="pill">
            <div class="pill__l">City sites</div>
            <div class="pill__v"><b>{c.dist.sites?.mean ?? '—'}</b> <span class="pm">±{c.dist.sites?.sd ?? 0}</span></div>
            <div class="pill__r">min {c.dist.sites?.min} · <b>med {c.dist.sites?.med}</b> · max {c.dist.sites?.max}</div>
            <div class="pill__bar" title="More vs fewer city sites, relative to the other maps"><span style={barStyle(c.dist.sites?.mean, pillRange.sites)}></span></div>
          </div>
          <div class="pill">
            <div class="pill__l">Land hex distance</div>
            {c.dist.land ? (<>
              <div class="pill__v"><b>{c.dist.land.mean}</b> <span class="pm">±{c.dist.land.sd}</span></div>
              <div class="pill__r">min {c.dist.land.min} · <b>med {c.dist.land.med}</b> · max {c.dist.land.max}</div>
              <div class="pill__bar" title="Longer vs shorter cap→cap land distance, relative to the other maps"><span style={barStyle(c.dist.land.mean, pillRange.land)}></span></div>
            </>) : <div class="pill__v dash">—</div>}
          </div>
          <div class="pill">
            <div class="pill__l">Land hex cost</div>
            {c.dist.slLand ? (<>
              <div class="pill__v"><b>{c.dist.slLand.mean}</b> <span class="pm">±{c.dist.slLand.sd}</span></div>
              <div class="pill__r">min {c.dist.slLand.min} · <b>med {c.dist.slLand.med}</b> · max {c.dist.slLand.max}</div>
              <div class="pill__bar" title="Higher vs lower move-cost, relative to the other maps"><span style={barStyle(c.dist.slLand.mean, pillRange.slLand)}></span></div>
            </>) : <div class="pill__v dash">—</div>}
          </div>
          <div class="pill">
            <div class="pill__l">Expansion space</div>
            {c.dist.expansion ? (<>
              <div class="pill__v"><b>{c.dist.expansion.mean}</b> <span class="pm">±{c.dist.expansion.sd}</span></div>
              <div class="pill__r">min {c.dist.expansion.min} · <b>med {c.dist.expansion.med}</b> · max {c.dist.expansion.max}</div>
              <div class="pill__bar" title="Buildable land tiles (could become urban) — more = roomier, less = more cramped, relative to the other maps"><span style={barStyle(c.dist.expansion.mean, pillRange.expansion)}></span></div>
            </>) : <div class="pill__v dash">—</div>}
          </div>
        </div>
        <div class="rstrip">
          <div class="rstrip__lab">Resource abundance
            <span class="rstrip__sub">green = lots · red = little, <i>relative to the other maps</i> · hover for exact amounts</span>
          </div>
          <div class="rstrip__ics">
            {RES_BARS.map((b: any) => {
              const bar = barOf(c, b.key);
              return (
                <div class="ric" title={barTip(b, bar.d)}>
                  <img src={`${baseUrl}img/icons/resources/${b.icon}.png`} alt={b.label} />
                  <div class="ric__bar"><span style={`width:${bar.w}%;background:${bar.col}`}></span></div>
                  <div class="ric__c">{b.label}</div>
                </div>
              );
            })}
          </div>
        </div>
        <details class="gal" open>
          <summary>{Math.min(c.imgs.length, 21)} generated maps</summary>
          <div class="gal__grid">
            {c.imgs.slice(0, 21).map((p: string) => {
              const id = idFromImg(c.slug, p);
              const gm = genMap[id] || {};
              return (
                <a class="gal__cell" href={`${baseUrl}gen/${id}`} target="_blank" rel="noopener">
                  <img src={`${baseUrl}img/${p}`} loading="lazy" alt={`${c.group} sample`} />
                  <div class="cap">
                    <span><i>sites</i><b>{gm.sites ?? '—'}</b></span>
                    <span><i>land</i><b>{gm.land ?? '—'}</b></span>
                    <span><i>cost</i><b>{gm.slLand ?? '—'}</b></span>
                  </div>
                </a>
              );
            })}
          </div>
        </details>
      </div>
        ))}
      </section>
    ))}
  </div>

  <p class="note">
    {pool.length} configs · {N}-ish seeds each. Pool is land-connected
    by construction; split-dropped % is how often a seed had no
    connected symmetric pair.
  </p>

  <style>
    .lede { font-family:var(--font-display); font-style:italic;
      font-size:1.05rem; line-height:1.55; color:var(--text-soft);
      max-width:80ch; margin:0.6rem 0 1.4rem; }
    .pool { display:flex; flex-direction:column; gap:2rem; }
    .tier { display:flex; flex-direction:column; gap:0.8rem; }
    .tier__h { display:flex; align-items:baseline; gap:0.7rem;
      flex-wrap:wrap; border-bottom:1px solid var(--gold-deep);
      padding-bottom:0.35rem; }
    .tier__t { font-family:var(--font-display); font-weight:700;
      font-size:1.55rem; color:var(--gold); }
    .tier__sub { font-family:var(--font-display); font-style:italic;
      font-size:0.92rem; color:var(--text-faint); }
    .tier__n { margin-left:auto; font-size:0.68rem;
      font-family:var(--font-mono); color:var(--text-dim);
      letter-spacing:0.08em; }
    .cfg { position:relative; display:flex; flex-direction:column;
